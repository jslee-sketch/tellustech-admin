/// 일정(마감)관리 — 반복주기 + 사전알림 + 대상직원 + 보고대상 + 연관모듈
model Schedule {
  id               String      @id @default(cuid())
  companyCode      CompanyCode
  scheduleCode     String      @unique // SCH-YYMMDD-###
  title            String
  dueAt            DateTime
  repeatCron       String? // 반복주기
  alertBeforeHours Int?
  relatedModule    String? // 연관 모듈명
  createdAt        DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt        DateTime    @updatedAt

  targets       Employee[]             @relation("ScheduleTargets")
  reporters     Employee[]             @relation("ScheduleReporters")
  confirmations ScheduleConfirmation[]

  @@index([companyCode, dueAt])
  @@map("schedules")
}

/// CFM 이력 — 직원이 모듈에서 CFM 클릭 시 기록, 보고자 알림, 지연 여부
model ScheduleConfirmation {
  id          String                @id @default(cuid())
  scheduleId  String
  employeeId  String
  confirmedAt DateTime              @default(now())
  status      ScheduleConfirmStatus
  note        String?

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([scheduleId])
  @@map("schedule_confirmations")
}

/// 라이선스관리 — 취득/만료/갱신, 사전알림, 갱신 후 차기일정 자동생성
model License {
  id                String      @id @default(cuid())
  companyCode       CompanyCode
  licenseCode       String      @unique // LIC-YYMMDD-###
  name              String
  ownerEmployeeId   String?
  acquiredAt        DateTime
  expiresAt         DateTime
  renewalCost       Decimal?    @db.Decimal(15, 2)
  alertBeforeDays   Int?
  certificateFileId String?
  createdAt         DateTime    @default(now())
  deletedAt   DateTime?
  updatedAt         DateTime    @updatedAt

  owner Employee? @relation(fields: [ownerEmployeeId], references: [id])

  @@index([companyCode, expiresAt])
  @@map("licenses")
}

// ==================================================
// 주간회의자료 — Backlog (영업 파이프라인) + 업무진행
// ==================================================

enum BacklogStatus {
  OPEN
  CLOSE
  NG
}

enum WeeklyTaskStatus {
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum WeeklySalesType {
  SALES   // 매출
  PURCHASE // 매입
}

model WeeklyBacklog {
  id                 String          @id @default(cuid())
  backlogCode        String          @unique // BL-YYMMDD-###
  companyCode        CompanyCode
  registeredAt       DateTime        @default(now())
  salesType          WeeklySalesType
  clientId           String
  salesEmployeeId    String?
  representativeItem String?
  amount             Decimal?        @db.Decimal(15, 2)
  currency           Currency        @default(VND)
  fxRate             Decimal         @default(1) @db.Decimal(15, 6)
  status             BacklogStatus   @default(OPEN)
  expectedCloseDate  DateTime?
  confirmedById      String?
  confirmedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  client        Client                 @relation(fields: [clientId], references: [id])
  salesEmployee Employee?              @relation("BacklogSalesEmployee", fields: [salesEmployeeId], references: [id])
  histories     WeeklyBacklogHistory[]

  @@index([companyCode, status])
  @@index([clientId])
  @@map("weekly_backlogs")
}

model WeeklyBacklogHistory {
  id           String   @id @default(cuid())
  backlogId    String
  date         DateTime @default(now())
  contentVi    String?
  contentEn    String?
  contentKo    String?
  originalLang Language @default(KO)
  writtenById  String?
  createdAt    DateTime @default(now())

  backlog WeeklyBacklog @relation(fields: [backlogId], references: [id], onDelete: Cascade)

  @@index([backlogId])
  @@map("weekly_backlog_histories")
}

model WeeklyTask {
  id              String           @id @default(cuid())
  taskCode        String           @unique // WT-YYMMDD-###
  companyCode     CompanyCode
  registeredAt    DateTime         @default(now())
  writerId        String
  assigneeId      String
  title           String
  instructionVi   String?
  instructionEn   String?
  instructionKo   String?
  instructionLang Language         @default(KO)
  contentVi       String?
  contentEn       String?
  contentKo       String?
  contentLang     Language         @default(KO)
  expectedEndDate DateTime?
  actualEndDate   DateTime?
  status          WeeklyTaskStatus @default(IN_PROGRESS)
  confirmedById   String?
  confirmedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  writer   Employee @relation("TaskWriter", fields: [writerId], references: [id])
  assignee Employee @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([companyCode, status])
  @@index([assigneeId])
  @@map("weekly_tasks")
}

// ==================================================
// 캘린더 — 자동수집 외 수동 이벤트
// ==================================================

enum CalendarEventType {
  SCHEDULE_DEADLINE
  WEEKLY_REPORT
  CONTRACT_EXPIRY
  CERT_EXPIRY
  LICENSE_EXPIRY
  AR_DUE
  LEAVE
  AS_DISPATCH
  RENTAL_ORDER
  BIRTHDAY
  HOLIDAY_VN
  HOLIDAY_KR
  CUSTOM
}

model CalendarEvent {
  id           String            @id @default(cuid())
  eventCode    String            @unique // EVT-YYMMDD-###
  companyCode  CompanyCode
  title        String
  titleVi      String?
  titleEn      String?
  titleKo      String?
  startDate    DateTime
  endDate      DateTime?
  allDay       Boolean           @default(true)
  eventType    CalendarEventType @default(CUSTOM)
  color        String?
  linkedModule String?
  linkedId     String?
  linkedUrl    String?
  assigneeId   String?
  description  String?
  createdAt    DateTime          @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
