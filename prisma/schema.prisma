// Tellustech ERP — Prisma Schema (Phase 1-2 v0.1)
//
// 출처: docs/CLAUDE_CODE_개발시작가이드.md 의 "DB 테이블 (44개)" 섹션.
// 가이드 헤더는 44이지만 세부 목록상 licenses 포함 45개 — 모두 포함.
// 규칙(CLAUDE.md):
//   - 회사코드(company_code): TV | VR. 세션 단위로 고정, 자동 WHERE 주입.
//   - 공유 마스터(company_code 없음): Client, Item, Warehouse 만.
//   - 그 외 업무 데이터는 company_code 필수. (가이드에서 "회사없음"으로 명시된 테이블 — it_contracts, tm_rentals, calibrations, as_tickets, sales, purchases, expenses — 은 거래처/계약 기반이므로 company_code 없음)
//   - 자유서술 필드는 contentVi / contentEn / contentKo + originalLang 4필드 구조.
//
// Phase 1-2에서 docs/db/ 의 상세 필드 정의서(.docx)와 대조하여 필드·인덱스를 보강할 것.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================================================
// Enums
// ==================================================

enum CompanyCode {
  TV
  VR
}

enum BranchType {
  BN // Bac Ninh (본사)
  HN // Ha Noi
  HCM // Ho Chi Minh
  NT // Nha Trang
  DN // Da Nang
}

enum Language {
  VI
  EN
  KO
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
  TECH
  CALIBRATION
  ACCOUNTING
  HR
  CLIENT // 고객 포탈
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum ItemType {
  PRODUCT // 상품 — 본체 장비, S/N 필수
  CONSUMABLE // 소모품 — 토너 등, S/N 필수
  PART // 부품 — Fuser/Drum 등, S/N 필수
  SUPPLIES // 비품 — A4용지·청소도구 등, S/N 없이 수량 기반 관리
}

enum WarehouseType {
  INTERNAL // 내부
  EXTERNAL // 외부
  CLIENT // 고객
}

enum ClientGrade {
  A
  B
  C
  D
}

enum ReceivableStatus {
  NORMAL
  WARNING
  BLOCKED // 미수금 차단
}

enum RentalType {
  IT
  TM
}

enum StockCheckMode {
  STRICT // IT렌탈 — 자사 재고 필수
  LOOSE // TM렌탈/교정/AS/매출/매입 — 경고만
}

/// 거래처 업종 — 프로토타입 P1 의 고정 선택지 유지.
enum Industry {
  MANUFACTURING
  LOGISTICS
  EDUCATION
  IT
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELED
  COMPLETED
}

enum BillingMethod {
  SNMP
  MANUAL
  PHOTO
}

enum InventoryTxnType {
  IN
  OUT
  TRANSFER
}

enum InventoryReason {
  // IN 사유 — 자사 자산 매입
  PURCHASE // 매입
  RETURN_IN // 반품입고
  OTHER_IN // 기타입고
  // IN 사유 — 타사 자산 입고 (서비스 목적, ownerClientId 필수)
  RENTAL_IN // 렌탈입고 (외주 렌탈로 빌려온 자산)
  REPAIR_IN // 수리입고 (고객 자산 수리 의뢰)
  DEMO_IN // 데모입고 (고객이 잠깐 사용 권한 부여)
  CALIBRATION_IN // 교정입고 (고객 자산 교정 의뢰)
  // OUT 사유
  SALE // 매출
  CONSUMABLE_OUT // 소모품출고 (IT 장비 대상)
  RENTAL_OUT // 렌탈반환 (RENTAL_IN 자산을 외주처에 반환)
  REPAIR_OUT // 수리완료반출 (REPAIR_IN 자산을 고객에게 반환)
  DEMO_OUT // 데모반환 (DEMO_IN 자산을 고객에게 반환)
  CALIBRATION_OUT // 교정완료반출 (CALIBRATION_IN 자산을 고객에게 반환)
  // TRANSFER 사유 (자사 내부 이동)
  CALIBRATION
  REPAIR
  RENTAL
  DEMO
}

// 자산 소유주 — 자사 vs 외부(고객/외주처)
enum AssetOwnerType {
  COMPANY // 자사 자산 (매입한 것)
  EXTERNAL_CLIENT // 외부 고객/외주처 자산 (수리/데모/교정/렌탈입고)
}

// Phase 1: 자동 매입·매출 후보 룰의 거래처별 예외만 저장.
// 기본 16개 룰은 코드 상수 (lib/inventory-rules.ts) 에 BASE_RULES 로 박힘.
// 이 테이블은 "이 거래처는 위탁 거래처라 자동 매입 안 잡음" 같은 운영 예외용.
model ClientRuleOverride {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation("ClientRuleOverride", fields: [clientId], references: [id], onDelete: Cascade)
  referenceModule     String   // RENTAL | REPAIR | CALIB | DEMO | TRADE
  // override 동작 — null 이면 BASE_RULES 무시 (후보 생성 안 함). 객체면 BASE_RULES 덮어씀.
  // ex: { autoPurchaseCandidate: false, autoSalesCandidate: false }
  overrideJson        Json?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([clientId, referenceModule])
  @@index([clientId])
  @@map("client_rule_overrides")
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum ASStatus {
  RECEIVED // 요청 (고객이 portal 에서 등록)
  IN_PROGRESS // 진행중 (담당자 배정 또는 출동)
  DISPATCHED // 출동중 (별칭 — IN_PROGRESS 의 세분)
  COMPLETED // 완료 (담당자가 마감)
  CONFIRMED // 확인 (고객이 portal 에서 컨펌)
  CANCELED
}

// AS 티켓 종류 — AS 요청 vs 소모품 요청 구분
enum AsTicketKind {
  AS_REQUEST
  SUPPLIES_REQUEST
}

enum IncidentType {
  PRAISE
  IMPROVEMENT
}

enum EvaluationGrade {
  A
  B
  C
  D
}

enum LeaveType {
  LT // 연차
  P // 병가
  KSX // 결근
  CT7 // 출장
  DB // (기획서 원문 코드 유지)
  TS // 시용
  KL // 결혼
  X // 기타
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseType {
  PURCHASE
  SALES
  GENERAL
  TRANSPORT // 교통비
  MEAL // 식대
  ENTERTAINMENT // 접대비
  RENT // 임대료
