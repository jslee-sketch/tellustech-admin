enum NotificationType {
  STOCK_LOW
  AS_NEW
  CONTRACT_EXPIRING
  CALIBRATION_DUE
  RECEIVABLE_OVERDUE
  SCHEDULE_DUE
  LICENSE_EXPIRING
  USAGE_CONFIRM_REQUEST
  YIELD_FRAUD_SUSPECT
  CASH_SHORTAGE_ALERT
  BUDGET_OVERRUN
  OTHER
}

enum FileCategory {
  PDF
  PHOTO
  SIGNATURE
  RECEIPT
  OTHER
}

enum ScheduleConfirmStatus {
  ON_TIME
  LATE
}

enum OnboardingOffboardingStatus {
  DRAFT
  SUBMITTED
  COMPLETED
}

enum ChatRoomType {
  DIRECT // 1:1
  GROUP
}

// 프로젝트(매출·매입) 분류. TRADE 만 재고 영향, 나머지는 S/N만 기록.
enum SalesType {
  TRADE // 판매/구매 — 재고 영향
  MAINTENANCE // 유지보수 — 기간 표시
  RENTAL // 렌탈 — 기간 표시
  CALIBRATION // 교정 — 라인별 성적서
  REPAIR // 수리
  OTHER // 기타
}

// 거래 통화. VND 가 회계 본위 통화(fxRate=1). 외화 거래는 입력 시점 환율을 함께 보관.
enum Currency {
  VND
  USD
  KRW
  JPY
  CNY
}

// ─── Adjustment / Amendment 공통 ──────────────────────────────────────
// 사후조정(Adjustment)은 매출/매입 발생 후의 반품·교환·금액조정.
// 계약변경(Amendment)은 IT/TM 계약의 장비 추가/제거/교체/단가변경/해지.
enum AdjustmentType {
  RETURN_FULL
  RETURN_PARTIAL
  EXCHANGE_FULL
  EXCHANGE_PARTIAL
  PRICE_ADJUST
}

enum AdjustmentItemAction {
  RETURN
  EXCHANGE_OUT // sales 의 경우 새 출고
  EXCHANGE_IN // purchase 의 경우 새 입고
}

enum AmendmentType {
  REMOVE_EQUIPMENT
  ADD_EQUIPMENT
  REPLACE_EQUIPMENT
  PRICE_CHANGE
  TERMINATE
}

enum AmendmentItemAction {
  REMOVE
  ADD
  REPLACE_OUT
  REPLACE_IN
}

enum AmendmentSource {
  CONTRACT_DETAIL
  INVENTORY_TXN
}

// ==================================================
// 기초등록 (7)
// ==================================================

model Department {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  code        String
  name        String
  branchType  BranchType
  managerId   String?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime    @updatedAt

  manager            Employee?           @relation("DepartmentManager", fields: [managerId], references: [id])
  employees          Employee[]          @relation("DepartmentMembers")
  expenseAllocations ExpenseAllocation[] @relation("ExpenseAllocDept")

  @@unique([companyCode, code])
  @@index([companyCode])
  @@map("departments")
}

// NOTE: Employee gets lockedAt/lockReason via the post-add (퇴사 후 잠금 정책).
model Employee {
  id              String         @id @default(cuid())
  companyCode     CompanyCode
  employeeCode    String // TNV-### (TV) / VNV-### (VR)
  departmentId    String?
  nameVi          String
  nameEn          String?
  nameKo          String?
  position        String?
  email           String?
  phone           String?
  photoUrl        String?
  idCardNumber    String?
  idCardPhotoUrl  String?
  salary          Decimal?       @db.Decimal(15, 2)
  insuranceNumber String?
  contractType    String?
  contractStart   DateTime?
  contractEnd     DateTime?
  hireDate        DateTime?
  birthDate       DateTime? // 캘린더 생일 표시용
  status          EmployeeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  deletedAt       DateTime?
  lockedAt        DateTime?
  lockReason      String?
  updatedAt       DateTime       @updatedAt

  department            Department?            @relation("DepartmentMembers", fields: [departmentId], references: [id])
  departmentsManaged    Department[]           @relation("DepartmentManager")
  user                  User?
  payrolls              Payroll[]
  incentives            Incentive[]
  leaveRecords          LeaveRecord[]
  incidentsWritten      Incident[]             @relation("IncidentAuthor")
  incidentsReceived     Incident[]             @relation("IncidentSubject")
  peerReviewsGiven      PeerReview[]           @relation("PeerReviewReviewer")
  peerReviewsGot        PeerReview[]           @relation("PeerReviewSubject")
  evaluationsOf         Evaluation[]           @relation("EvaluationSubject")
  regularEvalsGiven     RegularEvaluation[]    @relation("RegularEvalReviewer")
  regularEvalsGot       RegularEvaluation[]    @relation("RegularEvalSubject")
  onboarding            OnboardingCard?
  offboarding           OffboardingCard?
  asTicketsAssigned     AsTicket[]             @relation("AsAssignee")
  asDispatches          AsDispatch[]           @relation("DispatchEmployee")
  scheduleTargets       Schedule[]             @relation("ScheduleTargets")
  scheduleReports       Schedule[]             @relation("ScheduleReporters")
  scheduleConfirms      ScheduleConfirmation[]
  licensesOwned         License[]
  clientsReferred       Client[]               @relation("EmployeeReferredClients")
  clientsSalesPic       Client[]               @relation("EmployeeSalesPicClients")
  weeklyBacklogsAsSales WeeklyBacklog[]        @relation("BacklogSalesEmployee")
  weeklyTasksWritten    WeeklyTask[]           @relation("TaskWriter")
  weeklyTasksAssigned   WeeklyTask[]           @relation("TaskAssignee")
  calendarEvents        CalendarEvent[]
  prContactLogs         PrContactLog[]         @relation("PrContactedBy")
  prPaymentsRecorded    PrPayment[]            @relation("PrPaymentRecordedBy")

  // Phase A 포탈 확장
  feedbackTargeted  PortalFeedback[] @relation("FeedbackTarget")
  quotesAssigned    QuoteRequest[]   @relation("QuoteAssignee")
  referralsAssigned Referral[]       @relation("ReferralAssignee")

  @@unique([companyCode, employeeCode])
  @@index([companyCode])
  @@index([departmentId])
  @@map("employees")
}

/// 공유 마스터 — company_code 없음
model Client {
  id                 String            @id @default(cuid())
  clientCode         String            @unique
  companyNameVi      String
  companyNameEn      String?
  companyNameKo      String?
  representative     String? // 대표자
  taxCode            String?
  businessLicenseNo  String?
  industry           Industry?
  bankAccountNumber  String?
  bankName           String?
  bankHolder         String? // 예금주
  paymentTerms       Int? // 결제조건 (일). null = 30일 기본으로 해석
  address            String?
  phone              String?
  email              String?
  emailConsent       Boolean           @default(false) // 마케팅 이메일 수신 동의
  leadSource         String?
  referrerId         String? // 거래처가 다른 거래처 소개 (referrerClientId 의미)
  referrerEmployeeId String? // 내부 직원이 소개한 경우
  salesPicId         String? // 영업담당 직원 (sales PIC)
  grade              ClientGrade?
  marketingTags      String[] // groupTags 와 동일 의미
  receivableStatus   ReceivableStatus  @default(NORMAL)
  // 포탈 포인트 사용 정책 — 계약 시점에 결정. 고객은 이 범위 안에서만 교환 신청 가능.
  // 대기업 컴플라이언스 (개인 상품권 수령 금지 등) 대응.
  pointPolicy        ClientPointPolicy @default(NONE)
  notes              String?
  createdAt          DateTime          @default(now())
  deletedAt          DateTime?
  updatedAt          DateTime          @updatedAt

  referrer         Client?                @relation("ClientReferrer", fields: [referrerId], references: [id])
  referrals        Client[]               @relation("ClientReferrer")
  referrerEmployee Employee?              @relation("EmployeeReferredClients", fields: [referrerEmployeeId], references: [id])
  salesPic         Employee?              @relation("EmployeeSalesPicClients", fields: [salesPicId], references: [id])
  contacts         ClientContact[]
  portalUser       User?                  @relation("ClientPortalUser")
  itContracts      ItContract[]
  tmRentals        TmRental[]
  asTickets        AsTicket[]
  sales            Sales[]
  purchases        Purchase[]
  campaigns        MarketingCampaign[]    @relation("CampaignClient")
  inventoryTxns    InventoryTransaction[] @relation("InventoryTxnClient")
  ownedInventoryItems InventoryItem[]     @relation("InvItemOwnerClient")
  ruleOverrides    ClientRuleOverride[]   @relation("ClientRuleOverride")
  weeklyBacklogs   WeeklyBacklog[]

  // Phase A 포탈 확장
  portalPoints        PortalPoint[]
  portalRewards       PortalReward[]
  portalFeedback      PortalFeedback[]
  quoteRequests       QuoteRequest[]
  surveyResponses     SurveyResponse[]
  referralsAsReferrer Referral[]          @relation("ReferralReferrer")
  portalPostViews     PortalPostView[]
  // SNMP / 사용량 확인서
  usageConfirmations  UsageConfirmation[]
  // Layer 1 — Expense 강화 역참조
  expenseAsVendor     Expense[]           @relation("ExpenseVendor")
  expenseAsTarget     Expense[]           @relation("ExpenseTargetClient")
  cashTransactions    CashTransaction[]   @relation("CashTxnClient")

  @@index([referrerEmployeeId])
  @@index([salesPicId])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

/// 공유 마스터 — company_code 없음. 품목명은 영어로만 관리.
model Item {
  id                String        @id @default(cuid())
  itemCode          String        @unique
  itemType          ItemType
  name              String // 품목명 — 영어로만 입력
  unit              String?
  // 설명 — 자유 텍스트 (구 category 필드 의 이름 변경 + 의미 확장). 검색·표시용.
  description       String        @default("")
  reorderPoint      Int? // 재고부족 알림 임계치 — null 이면 알림 없음(소모품 계열에서만 의미)
  // 소모품 적정율 계산 — itemType=CONSUMABLE/PART 일 때만 의미.
  expectedYield     Int?
  yieldCoverageBase Int?          @default(5)
  yieldUnit         String?       @default("pages")
  // 색상 채널 — 토너/드럼/퓨저 분류. 적정율 계산에 사용. NONE 또는 null 이면 BW 합산.
  colorChannel      ColorChannel?
  // BOM (Bill of Materials) — 3단계 트리.
  parentItemId      String?
  parentItem        Item?         @relation("ItemBOM", fields: [parentItemId], references: [id])
  childItems        Item[]        @relation("ItemBOM")
  bomQuantity       Decimal?      @default(1) @db.Decimal(10, 2)
  bomLevel          Int?          @default(0) // 0=독립, 1=A'ssy, 2=서브, 3=구성
  bomNote           String?
  createdAt         DateTime      @default(now())
  deletedAt         DateTime?
  updatedAt         DateTime      @updatedAt

  inventoryStocks       InventoryStock[]
  inventoryTransactions InventoryTransaction[]
  assetDepreciations    AssetDepreciation[]
  salesItems            SalesItem[]
  purchaseItems         PurchaseItem[]
  tmRentalItems         TmRentalItem[]
  itContractEquipment   ItContractEquipment[]
  dispatchParts         AsDispatchPart[]
  inventoryItems        InventoryItem[]
  // M:N 호환 매핑 — 본체 장비 ↔ 호환 소모품
  compatProducts        ItemCompatibility[]    @relation("CompatProductItem")
  compatConsumables     ItemCompatibility[]    @relation("CompatConsumableItem")

  @@index([parentItemId])
  @@index([itemType])
  @@index([colorChannel])
  @@map("items")
}

enum ColorChannel {
  BLACK
  CYAN
  MAGENTA
  YELLOW
  DRUM
  FUSER
  NONE
}

// 본체 장비(productItem) ↔ 호환 소모품(consumableItem) 매핑.
// portal 소모품 요청 시 본인 IT 계약 장비의 itemId 들로 호환 소모품 조회.
model ItemCompatibility {
  id               String   @id @default(cuid())
  productItemId    String // 본체 장비 (예: ItemType=PRODUCT)
  consumableItemId String // 소모품 (예: ItemType=CONSUMABLE)
  note             String?
  createdAt        DateTime @default(now())

  product    Item @relation("CompatProductItem", fields: [productItemId], references: [id], onDelete: Cascade)
  consumable Item @relation("CompatConsumableItem", fields: [consumableItemId], references: [id], onDelete: Cascade)

  @@unique([productItemId, consumableItemId])
  @@index([productItemId])
  @@index([consumableItemId])
  @@map("item_compatibilities")
}

/// S/N 단위 재고 마스터 — 상태/QR/이력 관리
model InventoryItem {
  id           String      @id @default(cuid())
  itemId       String
  item         Item        @relation(fields: [itemId], references: [id])
  serialNumber String      @unique
  warehouseId  String
  warehouse    Warehouse   @relation("InventoryItemWarehouse", fields: [warehouseId], references: [id])
  companyCode  CompanyCode

  status                InventoryStatus @default(NORMAL)
  qrData                String?
  acquiredAt            DateTime?
  lastStatusChange      DateTime?
  // ── 현상태 기술 (자유 텍스트 3국어 자동번역). 양품/불량 사유 등. ──
  stateNoteVi           String?
  stateNoteEn           String?
  stateNoteKo           String?
  stateNoteOriginalLang Language?

  // ── 자산 소유주 추적 ──
  // COMPANY = 자사 자산 (매입). EXTERNAL_CLIENT = 외부 자산 (수리/데모/교정/렌탈입고).
  // ownerClientId 는 EXTERNAL_CLIENT 일 때 거래처/외주처 ID. inboundReason 으로 입고 사유 보존.
  ownerType        AssetOwnerType  @default(COMPANY)
  ownerClientId    String?
  ownerClient      Client?         @relation("InvItemOwnerClient", fields: [ownerClientId], references: [id])
  inboundReason    InventoryReason?
  inboundAt        DateTime?

  // ── Phase 1 추가 — 외부 위탁 위치 추적 + archive ──
  // currentLocationClientId NOT NULL = 자산이 외부 거래처(수리처/교정처/외주)에 위탁 중.
  // currentLocationSinceAt = 해당 위치 진입 시각 (장기 미회수 알림용).
  // archivedAt = 외부자산이 원소유주에게 반환된 시점. NOT NULL 이면 활성 재고에서 제외.
  currentLocationClientId String?
  currentLocationSinceAt  DateTime?
  archivedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  remarks InventoryRemark[]

  @@index([warehouseId])
  @@index([itemId])
  @@index([status])
  @@index([companyCode])
  @@map("inventory_items")
}

model InventoryRemark {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  date         DateTime @default(now())
  contentVi    String?
  contentEn    String?
  contentKo    String?
  originalLang String   @default("VI")

  writtenById String?
  createdAt   DateTime @default(now())

  @@index([inventoryItemId])
  @@map("inventory_remarks")
}

/// 공유 마스터 — company_code 없음
model Warehouse {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  warehouseType WarehouseType
  branchType    BranchType?
  location      String?
  createdAt     DateTime      @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime      @updatedAt

  inventoryStocks           InventoryStock[]
  inventoryTransactionsFrom InventoryTransaction[] @relation("FromWarehouse")
  inventoryTransactionsTo   InventoryTransaction[] @relation("ToWarehouse")
  inventoryItems            InventoryItem[]        @relation("InventoryItemWarehouse")
  salesAdjustments          SalesAdjustment[]      @relation("SalesAdjustmentWh")
  purchaseAdjustments       PurchaseAdjustment[]   @relation("PurchaseAdjustmentWh")
  itAmendments              ItContractAmendment[]  @relation("ItAmendmentWh")
  tmAmendments              TmRentalAmendment[]    @relation("TmAmendmentWh")

  @@map("warehouses")
}

model Project {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  projectCode String
  name        String
  salesType   SalesType
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime    @updatedAt

  sales              Sales[]
  purchases          Purchase[]
  expenseAllocations ExpenseAllocation[] @relation("ExpenseAllocProject")

  @@unique([companyCode, projectCode])
  @@index([companyCode])
  @@map("projects")
}

// ==================================================
// 렌탈 + IT계약 (4)
// ==================================================

/// 가이드: "회사코드 없음(거래처 기반)"
model ItContract {

  id                     String         @id @default(cuid())
  contractNumber         String         @unique // TLS-/VRT-YYMMDD-###
  clientId               String
  installationAddress    String?
  status                 ContractStatus @default(DRAFT)
  startDate              DateTime
  endDate                DateTime
  deposit                Decimal?       @db.Decimal(15, 2)
  installationFee        Decimal?       @db.Decimal(15, 2)
  deliveryFee            Decimal?       @db.Decimal(15, 2)
  additionalServiceFee   Decimal?       @db.Decimal(15, 2)
  currency               Currency       @default(VND)
  fxRate                 Decimal        @default(1) @db.Decimal(15, 6)
  // 담당자 3종 (이름 / HP / Office / Email)
  contractMgrName        String?
  contractMgrPhone       String?
  contractMgrOffice      String?
  contractMgrEmail       String?
  technicalMgrName       String?
  technicalMgrPhone      String?
  technicalMgrOffice     String?
  technicalMgrEmail      String?
  financeMgrName         String?
  financeMgrPhone        String?
  financeMgrOffice       String?
  financeMgrEmail        String?
  createdAt              DateTime       @default(now())
  deletedAt              DateTime?
  lockedAt               DateTime?
  lockReason             String?
  updatedAt              DateTime       @updatedAt
  // 매월 자동 SNMP 수집일 (1~28). 28 초과 입력 방지.
  snmpCollectDay         Int            @default(25)
  // 계약 단위 토큰 (에이전트 패키지 + register-devices 인증)
  contractToken          String?        @unique
  contractTokenExpiresAt DateTime?
  // 조기 종료 / 정상 종료 메타
  terminatedAt           DateTime?
  terminatedById         String?
  terminationReason      String?

  client              Client                   @relation(fields: [clientId], references: [id])
  monthlyBillings     ItMonthlyBilling[]
  rentalOrders        RentalOrder[]
  equipment           ItContractEquipment[]
  amendments          ItContractAmendment[]
  snmpReadings        SnmpReading[]
  usageConfirmations  UsageConfirmation[]
  agentHeartbeats     AgentHeartbeat[]
  unregisteredDevices SnmpUnregisteredDevice[]
  yieldAnalyses       YieldAnalysis[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@index([status])
  @@map("it_contracts")
}

/// IT계약의 장비 목록 (복수 S/N + 과금조건).
/// 하나의 IT계약에 수백 개까지 등록 가능. S/N 은 계약 내에서 유일.
model ItContractEquipment {

  id                   String    @id @default(cuid())
  itContractId         String
  itemId               String
  serialNumber         String
  manufacturer         String?
  installedAt          DateTime?
  removedAt            DateTime?
  monthlyBaseFee       Decimal?  @db.Decimal(15, 2)
  bwIncludedPages      Int?
  bwOverageRate        Decimal?  @db.Decimal(10, 2)
  colorIncludedPages   Int?
  colorOverageRate     Decimal?  @db.Decimal(10, 2)
  // SNMP 자동수집용 — IP 와 모델. 둘 다 null 이면 mock fallback.
  deviceIp             String?
  deviceModel          String?
  // 에이전트 인증 토큰 (UUID). 60일 미접속 자동 만료 + 관리자 [폐기] 가능.
  deviceToken          String?   @unique
  deviceTokenExpiresAt DateTime?
  deviceTokenRevokedAt DateTime?
  snmpCommunity        String?   @default("public")
  // 모니터링: 마지막 SNMP 수집 시각
  lastReadingAt        DateTime?
  // 설치 시점 카운터 (첫 달 prev 기준)
  installCounterBw     Int?
  installCounterColor  Int?
  // 카운터 리셋/메인보드 교체 시점 (수동 입력 — usage 계산 시 prev 무시)
  resetAt              DateTime?
  // 과금 기준 (지시문 별도 필드 — 기존 bwIncludedPages 와 병행 보존)
  baseIncludedBw       Int?      @default(0)
  baseIncludedColor    Int?      @default(0)
  extraRateBw          Decimal?  @db.Decimal(10, 2)
  extraRateColor       Decimal?  @db.Decimal(10, 2)
  note                 String?
  // 소모품 적정율 — 고객별 실제 상밀도 (%, 기본 5). 계약 협의/운영 중 조정.
  actualCoverage       Int?      @default(5)
  // 마지막 적정율 캐시 — 리스트 정렬/필터·뱃지 즉시 표시용.
  lastYieldRateBw      Decimal?  @db.Decimal(5, 1)
  lastYieldRateColor   Decimal?  @db.Decimal(5, 1)
  lastYieldCalcAt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  itContract    ItContract      @relation(fields: [itContractId], references: [id], onDelete: Cascade)
  item          Item            @relation(fields: [itemId], references: [id])
  snmpReadings  SnmpReading[]
  yieldAnalyses YieldAnalysis[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@unique([itContractId, serialNumber])
  @@index([itContractId])
  @@index([itemId])
  @@index([serialNumber])
  @@map("it_contract_equipment")
}

model ItMonthlyBilling {

  id                String        @id @default(cuid())
  itContractId      String
  billingMonth      DateTime // 첫째 날 기준
  serialNumber      String
  counterBw         Int? // 흑백 카운터
  counterColor      Int? // 컬러 카운터
  billingMethod     BillingMethod
  photoUrl          String?
  customerSignature String? // 전자서명 base64 또는 파일참조
  yieldVerified     Boolean       @default(false)
  computedAmount    Decimal?      @db.Decimal(15, 2)
  createdAt         DateTime      @default(now())
  deletedAt         DateTime?
  lockedAt          DateTime?
  lockReason        String?
  updatedAt         DateTime      @updatedAt

  itContract ItContract @relation(fields: [itContractId], references: [id], onDelete: Cascade)

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@unique([itContractId, serialNumber, billingMonth])
  @@index([itContractId])
  @@index([billingMonth])
  @@map("it_monthly_billing")
}

/// 가이드: "매출정보 먼저 + S/N별 매입정보 + 이익자동계산"
model TmRental {

  id                String         @id @default(cuid())
  rentalCode        String         @unique // TM-YYMMDD-###
  clientId          String
  contractNumber    String?
  address           String?
  // 담당자 3종
  contractMgrName   String?
  contractMgrPhone  String?
  contractMgrEmail  String?
  technicalMgrName  String?
  technicalMgrPhone String?
  technicalMgrEmail String?
  financeMgrName    String?
  financeMgrPhone   String?
  financeMgrEmail   String?
  startDate         DateTime
  endDate           DateTime
  currency          Currency       @default(VND)
  fxRate            Decimal        @default(1) @db.Decimal(15, 6)
  // 조기 종료 / 정상 종료 메타 (IT 계약과 동일 정책)
  status            ContractStatus @default(ACTIVE)
  terminatedAt      DateTime?
  terminatedById    String?
  terminationReason String?
  createdAt         DateTime       @default(now())
  deletedAt         DateTime?
  lockedAt          DateTime?
  lockReason        String?
  updatedAt         DateTime       @updatedAt

  client     Client              @relation(fields: [clientId], references: [id])
  items      TmRentalItem[]
  amendments TmRentalAmendment[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@map("tm_rentals")
}

/// TmRental의 품목세트 행 (수백 개 + 엑셀 업로드)
/// 매출 먼저 + S/N별 매입(매입처/매입금액/커미션) + 이익자동계산
model TmRentalItem {

  id            String   @id @default(cuid())
  tmRentalId    String
  itemId        String
  options       String?
  serialNumber  String
  startDate     DateTime
  endDate       DateTime
  salesPrice    Decimal  @db.Decimal(15, 2)
  supplierName  String?
  purchasePrice Decimal? @db.Decimal(15, 2)
  commission    Decimal? @db.Decimal(15, 2)
  profit        Decimal? @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tmRental         TmRental    @relation(fields: [tmRentalId], references: [id], onDelete: Cascade)
  item             Item        @relation(fields: [itemId], references: [id])
  reflectedInSales SalesItem[] @relation("TmRentalSalesItemSource")

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([tmRentalId])
  @@index([itemId])
  @@index([serialNumber])
  @@map("tm_rental_items")
}

model RentalOrder {
  id           String      @id @default(cuid())
  companyCode  CompanyCode
  itContractId String?
  rentalType   RentalType
  billingMonth DateTime // 월별 자동 복사
  amount       Decimal     @db.Decimal(15, 2)
  editable     Boolean     @default(true)
  canceled     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  itContract ItContract? @relation(fields: [itContractId], references: [id])

  @@index([companyCode, billingMonth])
  @@index([itContractId])
  @@map("rental_orders")
}

// ==================================================
// 재고 + 감가상각 (3)
// ==================================================

model InventoryStock {
  id            String      @id @default(cuid())
  companyCode   CompanyCode
  itemId        String
  warehouseId   String
  branchType    BranchType
  month         DateTime // 월 단위 스냅샷 (첫째 날)
  quantity      Int         @default(0)
  serialNumbers String[] // S/N 목록 (자산 추적용)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([companyCode, itemId, warehouseId, month])
  @@index([companyCode, branchType])
  @@map("inventory_stock")
}

model InventoryTransaction {
  id                String           @id @default(cuid())
  companyCode       CompanyCode
  itemId            String
  fromWarehouseId   String? // 출고창고 (IN 시 null, OUT/TRANSFER 시 필수)
  toWarehouseId     String? // 입고창고 (OUT 시 null 가능, IN/TRANSFER 시 필수)
  clientId          String? // External 창고 연관 고객
  serialNumber      String?
  txnType           InventoryTxnType
  reason            InventoryReason  // 레거시 — 점진 폐기. 신규 필드는 referenceModule+subKind.
  // ── Phase 1 신규 3축 분류 (referenceModule + subKind + ownerType (마스터에서 조회)) ──
  // 진리표 키 = (txnType, referenceModule, subKind, masterOwnerType). 자동 매입·매출 후보 결정.
  referenceModule   String?  // RENTAL | REPAIR | CALIB | DEMO | TRADE | CONSUMABLE | null
  subKind           String?  // REQUEST | RETURN | PURCHASE | SALE | BORROW | LEND | null (신규 NOT NULL 예정 — 백필 후 enforce)
  quantity          Int
  scannedBarcode    String?
  note              String?
  performedById     String?
  performedAt       DateTime         @default(now())
  // 소모품출고 시 대상 장비 추적
  targetEquipmentSN String?
  targetContractId  String?
  // TRANSFER External↔External 패스스루 시 양 끝점 거래처 (단일 clientId 외에 명시)
  fromClientId      String?
  toClientId        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  item          Item            @relation(fields: [itemId], references: [id])
  fromWarehouse Warehouse?      @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?      @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  client        Client?         @relation("InventoryTxnClient", fields: [clientId], references: [id])
  dispatchPart  AsDispatchPart? @relation("DispatchPartTxn")
  prDrafts      PayableReceivable[] @relation("PrFromInvTxn")

  @@index([companyCode, performedAt])
  @@index([serialNumber])
  @@index([targetEquipmentSN])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("inventory_transactions")
}

model AssetDepreciation {
  id                 String             @id @default(cuid())
  companyCode        CompanyCode
  itemId             String
  serialNumber       String
  acquisitionDate    DateTime
  acquisitionCost    Decimal            @db.Decimal(15, 2)
  method             DepreciationMethod
  usefulLifeMonths   Int
  month              DateTime // 월별 기록
  depreciationAmount Decimal            @db.Decimal(15, 2)
  bookValue          Decimal            @db.Decimal(15, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  item Item @relation(fields: [itemId], references: [id])

  @@unique([companyCode, serialNumber, month])
  @@index([companyCode])
  @@map("asset_depreciation")
}

// 교정 모듈 제거됨 — Sales/Purchase 에 projectType=CALIBRATION 으로 편입.

// ==================================================
// AS + 출동 (2)
// ==================================================

model AsTicket {

  id                String       @id @default(cuid())
  ticketNumber      String       @unique // YY/MM/DD-##
  kind              AsTicketKind @default(AS_REQUEST)
  clientId          String
  assignedToId      String?
  itemId            String?
  serialNumber      String?
  status            ASStatus     @default(RECEIVED)
  receivedAt        DateTime     @default(now())
  completedAt       DateTime?
  confirmedAt       DateTime? // 고객 confirm 시점
  // 소모품 요청 multi-item (AS 요청은 빈 배열)
  suppliesItems     Json? // [{itemId, quantity, note?}]
  // 증상(자유서술 AI 번역)
  symptomVi         String?
  symptomEn         String?
  symptomKo         String?
  originalLang      Language?
  receivableBlocked Boolean      @default(false) // 미수금 차단 자동 확인
  createdAt         DateTime     @default(now())
  deletedAt         DateTime?
  lockedAt          DateTime?
  lockReason        String?
  updatedAt         DateTime     @updatedAt

  client     Client       @relation(fields: [clientId], references: [id])
  assignedTo Employee?    @relation("AsAssignee", fields: [assignedToId], references: [id])
  dispatches AsDispatch[]
  photos     File[]       @relation("AsTicketPhotos")

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@index([status])
  @@index([serialNumber])
  @@map("as_tickets")
}

model AsDispatch {

  id                 String    @id @default(cuid())
  asTicketId         String
  dispatchEmployeeId String?
  transportMethod    String? // 출동수단
  originAddress      String?
  destinationAddress String?
  googleDistanceKm   Decimal?  @db.Decimal(10, 2)
  meterPhotoUrl      String?
  meterOcrKm         Decimal?  @db.Decimal(10, 2)
  distanceMatch      Boolean?
  transportCost      Decimal?  @db.Decimal(15, 2)
  receiptFileId      String?
  departedAt         DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?
  note               String?
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?
  lockedAt           DateTime?
  lockReason         String?
  updatedAt          DateTime  @updatedAt

  // 대상 장비 S/N (AS 티켓에서 자동 propagate, 사용자 변경 가능)
  targetEquipmentSN String?

  asTicket         AsTicket         @relation(fields: [asTicketId], references: [id], onDelete: Cascade)
  dispatchEmployee Employee?        @relation("DispatchEmployee", fields: [dispatchEmployeeId], references: [id])
  receipt          File?            @relation("DispatchReceipt", fields: [receiptFileId], references: [id])
  parts            AsDispatchPart[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([asTicketId])
  @@index([targetEquipmentSN])
  @@map("as_dispatches")
}

/// AS 출동 시 사용한 부품 — 출고 자동처리 + 매입원가 자동조회 + 장비 S/N 매핑
model AsDispatchPart {

  id           String     @id @default(cuid())
  asDispatchId String
  asDispatch   AsDispatch @relation(fields: [asDispatchId], references: [id], onDelete: Cascade)

  itemId       String
  item         Item    @relation(fields: [itemId], references: [id])
  serialNumber String? // 부품 자체 S/N (소모품은 없을 수 있음)
  quantity     Int     @default(1)

  // 대상 장비 S/N — 어떤 복합기/장비에 사용했는지 (필수)
  targetEquipmentSN String
  targetContractId  String? // ItContract id (자동조회로 채움)

  // 매입원가 (자동조회 + 수동수정 가능)
  unitCost  Decimal? @db.Decimal(15, 2)
  totalCost Decimal? @db.Decimal(15, 2)

  // 자동 생성된 출고 트랜잭션과 1:1
  inventoryTxnId String?               @unique
  inventoryTxn   InventoryTransaction? @relation("DispatchPartTxn", fields: [inventoryTxnId], references: [id])

  note      String?
  createdAt DateTime @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([asDispatchId])
  @@index([targetEquipmentSN])
  @@index([targetContractId])
  @@map("as_dispatch_parts")
}

// ==================================================
// 매출 / 매입 (4)
// ==================================================

/// 가이드: "회사없음 + 영업담당 추가 + 사용기간(optional)"
model Sales {

  id                   String    @id @default(cuid())
  salesNumber          String    @unique
  clientId             String
  projectId            String?
  salesEmployeeId      String?
  warehouseId          String? // TRADE 프로젝트 자동 OUT 대상 창고
  // OA(IT)/TM 분기 — 포탈 현황판이 itContractId 또는 tmRentalId 유무로 OA/TM 구분
  itContractId         String?
  tmRentalId           String?
  usagePeriodStart     DateTime?
  usagePeriodEnd       DateTime?
  // ── Mock 매출 워크플로 (cron 자동 생성 + 4단계 페르소나 뱃지) ──
  // billingMonth: 월 첫째 날 UTC (UsageConfirmation 과 매칭 키)
  billingMonth         DateTime?
  isDraft              Boolean   @default(false) // cron 이 만든 mock 인지
  technicianReady      Boolean   @default(false) // SNMP 수집·UC ADMIN_CONFIRMED 완료 (TM 은 항상 true)
  salesConfirmedById   String?
  salesConfirmedAt     DateTime? // 영업이 [매출 발행] 누른 시점
  financeConfirmedById String?
  financeConfirmedAt   DateTime? // 재경 CFM 시점
  totalAmount          Decimal   @db.Decimal(15, 2) // 거래통화(currency) 단위의 합계
  currency             Currency  @default(VND)
  fxRate               Decimal   @default(1) @db.Decimal(15, 6) // 1 단위 currency → VND 환산율
  note                 String?
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?
  lockedAt             DateTime?
  lockReason           String?
  updatedAt            DateTime  @updatedAt

  client         Client              @relation(fields: [clientId], references: [id])
  project        Project?            @relation(fields: [projectId], references: [id])
  items          SalesItem[]
  receivables    PayableReceivable[] @relation("SalesReceivable")
  adjustments    SalesAdjustment[]   @relation("SalesAdjustments")
  linkedExpenses Expense[]           @relation("ExpenseLinkedSales")

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  cashTransactions CashTransaction[] @relation("SalesCashTx")

  @@index([clientId])
  @@index([projectId])
  @@index([itContractId])
  @@index([tmRentalId])
  @@index([billingMonth])
  @@index([isDraft])
  @@map("sales")
}

model SalesItem {

  id                   String         @id @default(cuid())
  salesId              String
  itemId               String
  serialNumber         String?
  stockCheck           StockCheckMode @default(LOOSE)
  quantity             Decimal        @db.Decimal(15, 3)
  unitPrice            Decimal        @db.Decimal(15, 2)
  amount               Decimal        @db.Decimal(15, 2)
  // MAINTENANCE/RENTAL 프로젝트 타입 — 라인별 기간(헤더 기간 자동 복사, 라인별 수정 가능)
  startDate            DateTime?
  endDate              DateTime?
  // 교정(CALIBRATION) 프로젝트 타입인 경우 라인별 성적서 1건
  certNumber           String?        @unique
  certFileId           String?
  issuedAt             DateTime?
  nextDueAt            DateTime?
  alertedAt            DateTime?
  // TmRental → Sales 자동반영의 출처 (있으면 reflect-sales 가 1:1 복제한 것)
  sourceTmRentalItemId String?
  // Mock 매출 동기화 라벨 — UC ADMIN_CONFIRMED 시 어떤 라인을 삭제·재생성할지 식별.
  // BASE_FEE / EXTRA_BW / EXTRA_COLOR / TM_LINE / MANUAL
  sourceType           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  sales              Sales         @relation(fields: [salesId], references: [id], onDelete: Cascade)
  item               Item          @relation(fields: [itemId], references: [id])
  certFile           File?         @relation(fields: [certFileId], references: [id])
  sourceTmRentalItem TmRentalItem? @relation("TmRentalSalesItemSource", fields: [sourceTmRentalItemId], references: [id])

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([salesId])
  @@index([serialNumber])
  @@index([itemId])
  @@index([nextDueAt])
  @@index([sourceTmRentalItemId])
  @@map("sales_items")
}

model Purchase {

  id                   String    @id @default(cuid())
  purchaseNumber       String    @unique
  supplierId           String
  projectId            String?
  salesEmployeeId      String?
  warehouseId          String? // TRADE 프로젝트 자동 IN 대상 창고
  usagePeriodStart     DateTime?
  usagePeriodEnd       DateTime?
  totalAmount          Decimal   @db.Decimal(15, 2)
  currency             Currency  @default(VND)
  fxRate               Decimal   @default(1) @db.Decimal(15, 6)
  warehouseInboundDone Boolean   @default(false)
  note                 String?
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?
  lockedAt             DateTime?
  lockReason           String?
  updatedAt            DateTime  @updatedAt

  supplier       Client               @relation(fields: [supplierId], references: [id])
  project        Project?             @relation(fields: [projectId], references: [id])
  items          PurchaseItem[]
  payables       PayableReceivable[]  @relation("PurchasePayable")
  adjustments    PurchaseAdjustment[] @relation("PurchaseAdjustments")
  linkedExpenses Expense[]            @relation("ExpenseLinkedPurchase")
  cashTransactions CashTransaction[]  @relation("PurchaseCashTx")

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([supplierId])
  @@index([projectId])
  @@map("purchases")
}

model PurchaseItem {

  id           String         @id @default(cuid())
  purchaseId   String
  itemId       String
  serialNumber String?
  stockCheck   StockCheckMode @default(LOOSE)
  quantity     Decimal        @db.Decimal(15, 3)
  unitPrice    Decimal        @db.Decimal(15, 2)
  amount       Decimal        @db.Decimal(15, 2)
  // MAINTENANCE/RENTAL 프로젝트 타입 — 라인별 기간(헤더 기간 자동 복사, 라인별 수정 가능)
  startDate    DateTime?
  endDate      DateTime?
  // 교정(CALIBRATION) 프로젝트 타입인 경우 라인별 성적서 1건
  certNumber   String?        @unique
  certFileId   String?
  issuedAt     DateTime?
  nextDueAt    DateTime?
  alertedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])
  certFile File?    @relation(fields: [certFileId], references: [id])

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([purchaseId])
  @@index([serialNumber])
  @@index([itemId])
  @@index([nextDueAt])
  @@map("purchase_items")
}

// ==================================================
// 인사 + AI평가 (7)
// ==================================================

model Payroll {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  employeeId  String
  month       DateTime // 월별 급여명세 (첫째 날)
  baseSalary  Decimal     @db.Decimal(15, 2)
  allowances  Decimal     @default(0) @db.Decimal(15, 2)
  deductions  Decimal     @default(0) @db.Decimal(15, 2)
  netPay      Decimal     @db.Decimal(15, 2)
  // Layer 1 — 지급 처리
  paidAt              DateTime?
  paidById            String?
  bankAccountId       String?
  cashTransactionId   String?       @unique
  bankAccount         BankAccount?     @relation("PayrollAccount", fields: [bankAccountId], references: [id])
  cashTransaction     CashTransaction? @relation("PayrollCashTx", fields: [cashTransactionId], references: [id])

  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month])
  @@index([companyCode, month])
  @@index([paidAt])
  @@map("payroll")
}

model Incentive {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  employeeId  String
  month       DateTime
  source      String // 'TM' or 'IT'
  amount      Decimal     @db.Decimal(15, 2)
  note        String?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyCode, month])
  @@index([employeeId])
  @@map("incentives")
}

model LeaveRecord {
  id           String      @id @default(cuid())
  companyCode  CompanyCode
  leaveCode    String      @unique // LV-YYMMDD-###
  employeeId   String
  leaveType    LeaveType
  startDate    DateTime
  endDate      DateTime
  days         Decimal     @db.Decimal(5, 2)
  reason       String?
  reasonVi     String?
  reasonEn     String?
  reasonKo     String?
  originalLang Language?
  approverId   String?
  status       LeaveStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?
  lockedAt     DateTime?
  lockReason   String?
  updatedAt    DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyCode, employeeId])
  @@map("leave_records")
}

/// 사건기반 수시평가 — 대상자 본인 비공개, 상위만 열람, AI 번역, 50자 이상
model Incident {
  id                    String       @id @default(cuid())
  companyCode           CompanyCode
  incidentCode          String       @unique // INC-YYMMDD-###
  authorId              String
  subjectId             String
  type                  IncidentType
  contentVi             String?
  contentEn             String?
  contentKo             String?
  originalLang          Language?
  evidenceFileId        String?
  visibilityManagerOnly Boolean      @default(true)
  createdAt             DateTime     @default(now())
  deletedAt             DateTime?
  lockedAt              DateTime?
  lockReason            String?
  updatedAt             DateTime     @updatedAt

  author   Employee @relation("IncidentAuthor", fields: [authorId], references: [id])
  subject  Employee @relation("IncidentSubject", fields: [subjectId], references: [id])
  evidence File?    @relation("IncidentEvidence", fields: [evidenceFileId], references: [id])

  @@index([companyCode, subjectId])
  @@index([authorId])
  @@map("incidents")
}

/// 동료 상호평가 (익명, 치우침 자동감지)
model PeerReview {
  id           String      @id @default(cuid())
  companyCode  CompanyCode
  reviewerId   String // 내부 저장 (익명 표시)
  subjectId    String
  period       DateTime // 평가 기간
  score        Decimal     @db.Decimal(5, 2)
  biasDetected Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reviewer Employee @relation("PeerReviewReviewer", fields: [reviewerId], references: [id])
  subject  Employee @relation("PeerReviewSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId, period])
  @@map("peer_reviews")
}

/// AI 종합평가 (9개 지표, 가중치, 항목별+종합 이유, A/B/C/D, 관리자 ±10%)
model Evaluation {
  id                  String          @id @default(cuid())
  companyCode         CompanyCode
  evaluationCode      String          @unique // EVAL-YYMMDD-### (AI종합)
  subjectId           String
  period              DateTime
  // 9개 지표: AS TAT / 출동효율 / 매출기여 / ERP입력속도 / ERP마감준수 / ERP숙련도 / 근태 / 동료평가 / 사건평가
  scoreAsTat          Decimal?        @db.Decimal(5, 2)
  scoreDispatchEff    Decimal?        @db.Decimal(5, 2)
  scoreSalesContrib   Decimal?        @db.Decimal(5, 2)
  scoreErpInputSpeed  Decimal?        @db.Decimal(5, 2)
  scoreErpDeadline    Decimal?        @db.Decimal(5, 2)
  scoreErpMastery     Decimal?        @db.Decimal(5, 2)
  scoreAttendance     Decimal?        @db.Decimal(5, 2)
  scorePeer           Decimal?        @db.Decimal(5, 2)
  scoreIncident       Decimal?        @db.Decimal(5, 2)
  reasonsJson         Json? // 항목별 이유 (AI 생성)
  totalScore          Decimal         @db.Decimal(5, 2)
  totalReason         String?
  grade               EvaluationGrade
  managerAdjustment   Decimal?        @db.Decimal(5, 2) // ±10%
  managerAdjustReason String?
  createdAt           DateTime        @default(now())
  deletedAt           DateTime?
  lockedAt            DateTime?
  lockReason          String?
  updatedAt           DateTime        @updatedAt

  subject Employee @relation("EvaluationSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId, period])
  @@map("evaluations")
}

/// 정기 인사평가 (5단계, 100점 환산, 질문 사전등록)
model RegularEvaluation {
  id              String      @id @default(cuid())
  companyCode     CompanyCode
  evaluationCode  String      @unique
  reviewerId      String
  subjectId       String
  deadline        DateTime
  submittedAt     DateTime?
  answersJson     Json // 질문 ID -> 5단계 값(10/8/6/4/2)
  normalizedScore Decimal     @db.Decimal(5, 2) // 100점 만점
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reviewer Employee @relation("RegularEvalReviewer", fields: [reviewerId], references: [id])
  subject  Employee @relation("RegularEvalSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId])
  @@map("regular_evaluations")
}

// ==================================================
// 재경 (4)
// ==================================================

/// 비용 — Layer 1 강화: 결제방법 + 결제상태 + 발생업체 + 귀속고객 + 환급 워크플로
model Expense {

  id               String      @id @default(cuid())
  expenseCode      String      @unique // EXP-YYMMDD-###
  expenseType      ExpenseType
  linkedSalesId    String?
  linkedPurchaseId String?
  amount           Decimal     @db.Decimal(15, 2)
  currency         Currency    @default(VND)
  fxRate           Decimal     @default(1) @db.Decimal(15, 6)
  note             String?
  incurredAt       DateTime
  createdAt        DateTime    @default(now())
  deletedAt        DateTime?
  lockedAt         DateTime?
  lockReason       String?
  updatedAt        DateTime    @updatedAt

  // ── Layer 1 신규 필드 ──
  vendorClientId    String?
  vendorClient      Client?     @relation("ExpenseVendor", fields: [vendorClientId], references: [id])
  vendorName        String?     // 마스터에 없는 소액 거래처 (식당·주유소 등)
  targetClientId    String?
  targetClient      Client?     @relation("ExpenseTargetClient", fields: [targetClientId], references: [id])

  paymentMethod     ExpensePaymentMethod?
  paymentStatus     ExpensePaymentStatus  @default(PAID)
  reimbursedAt      DateTime?
  reimbursedById    String?
  reimburseCashTxId String?     // CashTransaction FK (환급 시점)
  reimburseCashTx   CashTransaction? @relation("ExpenseReimburseTx", fields: [reimburseCashTxId], references: [id])

  allocations      ExpenseAllocation[]
  payables         PayableReceivable[] @relation("ExpensePayable")
  linkedSales      Sales?              @relation("ExpenseLinkedSales", fields: [linkedSalesId], references: [id])
  linkedPurchase   Purchase?           @relation("ExpenseLinkedPurchase", fields: [linkedPurchaseId], references: [id])
  cashTransactions CashTransaction[]   @relation("ExpenseCashTx")

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([expenseType])
  @@index([linkedSalesId])
  @@index([linkedPurchaseId])
  @@index([vendorClientId])
  @@index([targetClientId])
  @@index([paymentStatus])
  @@map("expenses")
}

enum ExpensePaymentMethod {
  CORPORATE_CARD
  BANK_TRANSFER
  CASH_COMPANY
  CASH_PERSONAL
  CREDIT_PERSONAL
}

enum ExpensePaymentStatus {
  PAID
  PENDING_PAYMENT
  PENDING_REIMBURSE
  REIMBURSED
}

model ExpenseAllocation {

  id           String          @id @default(cuid())
  expenseId    String
  projectId    String?
  departmentId String?
  costCenterId String?         // Layer 2 — 비용 센터 배분
  basis        AllocationBasis
  weight       Decimal         @db.Decimal(10, 4) // 수량 또는 비율
  amount       Decimal         @db.Decimal(15, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  expense    Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  project    Project?    @relation("ExpenseAllocProject", fields: [projectId], references: [id])
  department Department? @relation("ExpenseAllocDept", fields: [departmentId], references: [id])
  costCenter CostCenter? @relation("ExpenseAllocCostCenter", fields: [costCenterId], references: [id])

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([expenseId])
  @@index([costCenterId])
  @@map("expense_allocations")
}

/// 미지급/미수금 — 매출/매입/비용에서 자동 생성 → 목록 선택 → 입금 확인 + 지연사유만 업데이트
model PayableReceivable {
  id             String                  @id @default(cuid())
  // 회사코드 — 자동생성 시 매출/매입의 sourceCompany 가 주입됨. 기존 행은 NULL(공유 거래처 정책 호환).
  companyCode    CompanyCode?
  kind           PayableReceivableKind
  salesId        String?
  purchaseId     String?
  expenseId      String?
  clientId       String?
  amount         Decimal                 @db.Decimal(15, 2)
  paidAmount     Decimal                 @default(0) @db.Decimal(15, 2)
  dueDate        DateTime? // 예정일 (최초 발행 시 결제조건으로 셋팅, 이후 불변 — 원래 약속된 날)
  revisedDueDate DateTime? // 변경일 (상세에서 수정 — null 이면 dueDate 와 동일하게 표시)
  status         PayableReceivableStatus @default(OPEN)
  createdAt      DateTime                @default(now())
  deletedAt      DateTime?
  lockedAt       DateTime?
  lockReason     String?
  updatedAt      DateTime                @updatedAt

  // 완료 추적 — 모두 입금/지급되면 자동 set
  completedAt DateTime?

  // Phase 2: 입출고에서 자동 생성된 DRAFT 후보가 어떤 InventoryTransaction 라인을 참조하는지.
  // 같은 거래처 DRAFT 끼리 묶어 정식 발행할 때 이 링크로 트레이스.
  sourceInventoryTxnId String?
  sourceInventoryTxn   InventoryTransaction? @relation("PrFromInvTxn", fields: [sourceInventoryTxnId], references: [id])

  sales          Sales?         @relation("SalesReceivable", fields: [salesId], references: [id])
  purchase       Purchase?      @relation("PurchasePayable", fields: [purchaseId], references: [id])
  expense        Expense?       @relation("ExpensePayable", fields: [expenseId], references: [id])
  delayReasons   DelayReason[]
  contactLogs    PrContactLog[]
  payments       PrPayment[]
  cashTransactions CashTransaction[] @relation("PrCashTx")
  // Phase A 포탈 — 포인트 청구액 차감 적용 이력
  appliedRewards PortalReward[] @relation("RewardAppliedToInvoice")

  @@index([companyCode, kind])
  @@index([kind, status])
  @@index([dueDate])
  @@map("payables_receivables")
}

/// 미수/미지급 담당자 연락 로그 — 고객(공급처)와의 연락내용 + 답변 + 예상입금
model PrContactLog {
  id                  String    @id @default(cuid())
  payableReceivableId String
  recordedAt          DateTime  @default(now())
  contactedById       String? // 담당 직원 (Employee.id)
  // 연락 내용 (3언어)
  contactNoteVi       String?
  contactNoteEn       String?
  contactNoteKo       String?
  // 고객 답변 (3언어)
  responseVi          String?
  responseEn          String?
  responseKo          String?
  originalLang        Language?
  // 예상 입금/지급
  expectedAmount      Decimal?  @db.Decimal(15, 2)
  expectedDate        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payableReceivable PayableReceivable @relation(fields: [payableReceivableId], references: [id], onDelete: Cascade)
  contactedBy       Employee?         @relation("PrContactedBy", fields: [contactedById], references: [id])

  @@index([payableReceivableId])
  @@index([recordedAt])
  @@map("pr_contact_logs")
}

/// 미수/미지급 입금 기록 (부분/전체) — paidAmount 자동 누적 + status 자동 갱신
model PrPayment {
  id                  String   @id @default(cuid())
  payableReceivableId String
  paidAt              DateTime @default(now())
  amount              Decimal  @db.Decimal(15, 2)
  method              String? // 송금/현금/수표 등
  reference           String? // 거래번호/은행
  recordedById        String? // 기록 직원 (Employee.id)
  note                String? // legacy 단일 컬럼 (호환용 — 신규 입력은 noteVi/En/Ko 로 저장)
  noteVi              String?
  noteEn              String?
  noteKo              String?
  noteOriginalLang    Language?
  createdAt           DateTime @default(now())

  payableReceivable PayableReceivable @relation(fields: [payableReceivableId], references: [id], onDelete: Cascade)
  recordedBy        Employee?         @relation("PrPaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([payableReceivableId])
  @@index([paidAt])
  @@map("pr_payments")
}

/// 지연사유 이력 (날짜+내용 복수기록, AI 번역)
model DelayReason {
  id                  String    @id @default(cuid())
  payableReceivableId String
  recordedAt          DateTime  @default(now())
  contentVi           String?
  contentEn           String?
  contentKo           String?
  originalLang        Language?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payableReceivable PayableReceivable @relation(fields: [payableReceivableId], references: [id], onDelete: Cascade)

  @@index([payableReceivableId])
  @@map("delay_reasons")
}

// ==================================================
// 시스템공통 (7)
// ==================================================

model User {
  id                 String        @id @default(cuid())
  username           String        @unique
  passwordHash       String
  email              String?       @unique
  employeeId         String?       @unique
  clientId           String?       @unique // 고객 포탈 사용자 — role=CLIENT
  allowedCompanies   CompanyCode[]
  role               UserRole
  preferredLang      Language      @default(KO)
  chatDisplayMode    Int           @default(1) // 1/2/3개 언어
  isActive           Boolean       @default(true)
  // 신규 발급 또는 관리자 리셋 직후 true. 사용자가 비밀번호를 변경하면 false.
  // 포탈에서는 true 인 동안 매 페이지마다 "비밀번호를 변경해주세요" 경고 배너 표시.
  mustChangePassword Boolean       @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  employee        Employee?        @relation(fields: [employeeId], references: [id])
  clientAccount   Client?          @relation("ClientPortalUser", fields: [clientId], references: [id])
  auditLogs       AuditLog[]
  notifications   Notification[]
  chatMessages    ChatMessage[]
  chatRoomMembers ChatRoomMember[]
  filesUploaded   File[]           @relation("FileUploader")
  permissions     UserPermission[]

  @@map("users")
}

// 코드 시퀀스 atomic counter — race condition 0.
// key = "<prefix>-<dateSeg>" 또는 "<prefix>" (sequential).
// upsert + 1 atomic 으로 다음 순번 발급.
model CodeSequence {
  /// 회사별 자동코드 시퀀스 (TNV-### vs VNV-### 분리). 마이그레이션 시 기존 행은 모두 TV 로 백필.
  companyCode CompanyCode @default(TV)
  key         String
  next        Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@id([companyCode, key])
  @@map("code_sequences")
}

// 사용자별 모듈 접근 권한 — 보기(VIEW) / 쓰기(WRITE) / 가림(HIDDEN)
// HIDDEN 이면 사이드바·접근 모두 차단. WRITE 면 작성·수정 모두 가능. VIEW 면 GET 만.
// role=ADMIN 은 자동으로 모든 모듈 WRITE — 이 테이블 무시.
model UserPermission {
  id        String           @id @default(cuid())
  userId    String
  module    PermissionModule
  level     PermissionLevel  @default(VIEW)
  updatedAt DateTime         @updatedAt
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@map("user_permissions")
}

enum PermissionLevel {
  HIDDEN
  VIEW
  WRITE
}

enum PermissionModule {
  CLIENTS
  ITEMS
  WAREHOUSES
  EMPLOYEES
  DEPARTMENTS
  PROJECTS
  LICENSES
  SCHEDULES
  SALES
  PURCHASES
  IT_CONTRACTS
  TM_RENTALS
  AS_TICKETS
  AS_DISPATCHES
  CALIBRATIONS
  INVENTORY
  HR_LEAVE
  HR_ONBOARDING
  HR_OFFBOARDING
  HR_INCIDENT
  HR_EVALUATION
  HR_PAYROLL
  HR_INCENTIVE
  FINANCE_PAYABLE
  FINANCE_RECEIVABLE
  FINANCE_EXPENSE
  STATS
  CHAT
  CALENDAR
  AUDIT
  ADMIN
}

model AuditLog {
  id          String       @id @default(cuid())
  companyCode CompanyCode?
  userId      String?
  tableName   String
  recordId    String
  action      String // INSERT / UPDATE / DELETE
  before      Json?
  after       Json?
  occurredAt  DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([companyCode, occurredAt])
  @@map("audit_log")
}

model Notification {
  id          String           @id @default(cuid())
  companyCode CompanyCode?
  userId      String
  type        NotificationType
  titleVi     String?
  titleEn     String?
  titleKo     String?
  bodyVi      String?
  bodyEn      String?
  bodyKo      String?
  linkUrl     String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}

model File {
  id           String       @id @default(cuid())
  uploaderId   String?
  category     FileCategory
  originalName String
  storedPath   String
  mimeType     String?
  sizeBytes    Int?
  compressed   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  uploader          User?          @relation("FileUploader", fields: [uploaderId], references: [id])
  salesItemCerts    SalesItem[]
  purchaseItemCerts PurchaseItem[]
  asTicketPhotos    AsTicket[]     @relation("AsTicketPhotos")
  dispatchReceipts  AsDispatch[]   @relation("DispatchReceipt")
  incidentEvidence  Incident[]     @relation("IncidentEvidence")

  @@map("files")
}

model MarketingCampaign {
  id          String       @id @default(cuid())
  companyCode CompanyCode?
  name        String
  type        String // 'SURVEY' or 'EMAIL'
  clientId    String?
  startDate   DateTime?
  endDate     DateTime?
  contentJson Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client? @relation("CampaignClient", fields: [clientId], references: [id])

  @@map("marketing_campaigns")
}

model ChatRoom {
  id          String       @id @default(cuid())
  companyCode CompanyCode?
  type        ChatRoomType
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members  ChatRoomMember[]
  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatRoomMember {
  chatRoomId String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([chatRoomId, userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id           String   @id @default(cuid())
  chatRoomId   String
  senderId     String
  contentVi    String?
  contentEn    String?
  contentKo    String?
  originalLang Language
  mentions     String[] // 예: ["AS-26/04/23-01", "TLS-260401-001"]
  attachmentId String?
  createdAt    DateTime @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId, createdAt])
  @@map("chat_messages")
}

// ==================================================
// 기초등록 확장 (5) — 가이드 헤더는 "4"이지만 licenses 포함 5개
// ==================================================

model OnboardingCard {
  id               String                      @id @default(cuid())
  companyCode      CompanyCode
  onboardingCode   String                      @unique // ONB-YYMMDD-###
  employeeId       String                      @unique
  personalInfo     Json
  education        Json?
  consentSignature String?
  profilePhotoId   String?
  generatedPdfId   String?
  status           OnboardingOffboardingStatus @default(DRAFT)
  createdAt        DateTime                    @default(now())
  deletedAt        DateTime?
  lockedAt         DateTime?
  lockReason       String?
  updatedAt        DateTime                    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("onboarding_cards")
}

model OffboardingCard {
  id                  String                      @id @default(cuid())
  companyCode         CompanyCode
  offboardingCode     String                      @unique // OFF-YYMMDD-###
  employeeId          String                      @unique
  returnedItems       Json? // 반납 체크리스트
  paidItems           Json? // 지급
  stoppedItems        Json? // 중지
  issuedItems         Json? // 생성(증명서)
  hrSignature         String?
  accountingSignature String?
  employeeSignature   String?
  generatedPdfId      String?
  status              OnboardingOffboardingStatus @default(DRAFT)
  createdAt           DateTime                    @default(now())
  deletedAt           DateTime?
  lockedAt            DateTime?
  lockReason          String?
  updatedAt           DateTime                    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("offboarding_cards")
}

/// 일정(마감)관리 — 반복주기 + 사전알림 + 대상직원 + 보고대상 + 연관모듈
model Schedule {
  id               String      @id @default(cuid())
  companyCode      CompanyCode
  scheduleCode     String      @unique // SCH-YYMMDD-###
  title            String
  dueAt            DateTime
  repeatCron       String? // 반복주기
  alertBeforeHours Int?
  relatedModule    String? // 연관 모듈명
  createdAt        DateTime    @default(now())
  deletedAt        DateTime?
  lockedAt         DateTime?
  lockReason       String?
  updatedAt        DateTime    @updatedAt

  targets       Employee[]             @relation("ScheduleTargets")
  reporters     Employee[]             @relation("ScheduleReporters")
  confirmations ScheduleConfirmation[]

  @@index([companyCode, dueAt])
  @@map("schedules")
}

/// CFM 이력 — 직원이 모듈에서 CFM 클릭 시 기록, 보고자 알림, 지연 여부
model ScheduleConfirmation {
  id          String                @id @default(cuid())
  scheduleId  String
  employeeId  String
  confirmedAt DateTime              @default(now())
  status      ScheduleConfirmStatus
  note        String?

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([scheduleId])
  @@map("schedule_confirmations")
}

/// 라이선스관리 — 취득/만료/갱신, 사전알림, 갱신 후 차기일정 자동생성
model License {
  id                String      @id @default(cuid())
  companyCode       CompanyCode
  licenseCode       String      @unique // LIC-YYMMDD-###
  name              String
  ownerEmployeeId   String?
  acquiredAt        DateTime
  expiresAt         DateTime
  renewalCost       Decimal?    @db.Decimal(15, 2)
  alertBeforeDays   Int?
  certificateFileId String?
  createdAt         DateTime    @default(now())
  deletedAt         DateTime?
  updatedAt         DateTime    @updatedAt

  owner Employee? @relation(fields: [ownerEmployeeId], references: [id])

  @@index([companyCode, expiresAt])
  @@map("licenses")
}

// ==================================================
// 주간회의자료 — Backlog (영업 파이프라인) + 업무진행
// ==================================================

enum BacklogStatus {
  OPEN
  CLOSE
  NG
}

enum WeeklyTaskStatus {
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum WeeklySalesType {
  SALES // 매출
  PURCHASE // 매입
}

model WeeklyBacklog {
  id                 String          @id @default(cuid())
  backlogCode        String          @unique // BL-YYMMDD-###
  companyCode        CompanyCode
  registeredAt       DateTime        @default(now())
  salesType          WeeklySalesType
  clientId           String
  salesEmployeeId    String?
  representativeItem String?
  amount             Decimal?        @db.Decimal(15, 2)
  currency           Currency        @default(VND)
  fxRate             Decimal         @default(1) @db.Decimal(15, 6)
  status             BacklogStatus   @default(OPEN)
  expectedCloseDate  DateTime?
  confirmedById      String?
  confirmedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  client        Client                 @relation(fields: [clientId], references: [id])
  salesEmployee Employee?              @relation("BacklogSalesEmployee", fields: [salesEmployeeId], references: [id])
  histories     WeeklyBacklogHistory[]

  @@index([companyCode, status])
  @@index([clientId])
  @@map("weekly_backlogs")
}

model WeeklyBacklogHistory {
  id           String   @id @default(cuid())
  backlogId    String
  date         DateTime @default(now())
  contentVi    String?
  contentEn    String?
  contentKo    String?
  originalLang Language @default(KO)
  writtenById  String?
  createdAt    DateTime @default(now())

  backlog WeeklyBacklog @relation(fields: [backlogId], references: [id], onDelete: Cascade)

  @@index([backlogId])
  @@map("weekly_backlog_histories")
}

model WeeklyTask {
  id              String           @id @default(cuid())
  taskCode        String           @unique // WT-YYMMDD-###
  companyCode     CompanyCode
  registeredAt    DateTime         @default(now())
  writerId        String
  assigneeId      String
  title           String
  instructionVi   String?
  instructionEn   String?
  instructionKo   String?
  instructionLang Language         @default(KO)
  contentVi       String?
  contentEn       String?
  contentKo       String?
  contentLang     Language         @default(KO)
  expectedEndDate DateTime?
  actualEndDate   DateTime?
  status          WeeklyTaskStatus @default(IN_PROGRESS)
  confirmedById   String?
  confirmedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  writer   Employee @relation("TaskWriter", fields: [writerId], references: [id])
  assignee Employee @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([companyCode, status])
  @@index([assigneeId])
  @@map("weekly_tasks")
}

// ==================================================
// 캘린더 — 자동수집 외 수동 이벤트
// ==================================================

enum CalendarEventType {
  SCHEDULE_DEADLINE
  WEEKLY_REPORT
  CONTRACT_EXPIRY
  CERT_EXPIRY
  LICENSE_EXPIRY
  AR_DUE
  LEAVE
  AS_DISPATCH
  RENTAL_ORDER
  BIRTHDAY
  HOLIDAY_VN
  HOLIDAY_KR
  CUSTOM
}

model CalendarEvent {
  id           String            @id @default(cuid())
  eventCode    String            @unique // EVT-YYMMDD-###
  companyCode  CompanyCode
  title        String
  titleVi      String?
  titleEn      String?
  titleKo      String?
  startDate    DateTime
  endDate      DateTime?
  allDay       Boolean           @default(true)
  eventType    CalendarEventType @default(CUSTOM)
  color        String?
  linkedModule String?
  linkedId     String?
  linkedUrl    String?
  assigneeId   String?
  description  String?
  createdAt    DateTime          @default(now())
  deletedAt    DateTime?
  lockedAt     DateTime?
  lockReason   String?
  updatedAt    DateTime          @updatedAt

  assignee Employee? @relation(fields: [assigneeId], references: [id])

  @@index([companyCode, startDate])
  @@index([assigneeId])
  @@map("calendar_events")
}

// ==================================================
// Adjustment / Amendment — 사후조정 + 계약변경
// ==================================================

/// 매출 사후조정 (반품/교환/금액조정).
/// quantity 는 항상 1 (S/N 단위) — items 행 1개 = S/N 1개.
model SalesAdjustment {
  id              String         @id @default(cuid())
  adjustCode      String         @unique // ADJ-S-YYMMDD-###
  companyCode     CompanyCode
  originalSalesId String
  type            AdjustmentType
  reason          String?
  reasonVi        String?
  reasonEn        String?
  reasonKo        String?
  warehouseId     String? // PRICE_ADJUST 만 null 가능
  performedAt     DateTime       @default(now())
  performedById   String
  // 회계 영향 — refundAmount (반품으로 차감), newAmount (교환/추가로 가산), netAmount = newAmount - refundAmount
  refundAmount    Decimal        @default(0) @db.Decimal(15, 2)
  newAmount       Decimal        @default(0) @db.Decimal(15, 2)
  netAmount       Decimal        @default(0) @db.Decimal(15, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  originalSales Sales                 @relation("SalesAdjustments", fields: [originalSalesId], references: [id])
  warehouse     Warehouse?            @relation("SalesAdjustmentWh", fields: [warehouseId], references: [id])
  items         SalesAdjustmentItem[]

  @@index([companyCode])
  @@index([originalSalesId])
  @@map("sales_adjustments")
}

model SalesAdjustmentItem {
  id                  String               @id @default(cuid())
  adjustmentId        String
  action              AdjustmentItemAction
  serialNumber        String
  itemId              String
  originalSalesItemId String?
  unitPrice           Decimal              @db.Decimal(15, 2)
  createdAt           DateTime             @default(now())

  adjustment SalesAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@index([serialNumber])
  @@index([originalSalesItemId])
  @@map("sales_adjustment_items")
}

/// 매입 사후조정 — 매출과 대칭. RETURN=출고, EXCHANGE_IN=새 입고.
model PurchaseAdjustment {
  id                 String         @id @default(cuid())
  adjustCode         String         @unique // ADJ-P-YYMMDD-###
  companyCode        CompanyCode
  originalPurchaseId String
  type               AdjustmentType
  reason             String?
  reasonVi           String?
  reasonEn           String?
  reasonKo           String?
  warehouseId        String?
  performedAt        DateTime       @default(now())
  performedById      String
  refundAmount       Decimal        @default(0) @db.Decimal(15, 2)
  newAmount          Decimal        @default(0) @db.Decimal(15, 2)
  netAmount          Decimal        @default(0) @db.Decimal(15, 2)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  originalPurchase Purchase                 @relation("PurchaseAdjustments", fields: [originalPurchaseId], references: [id])
  warehouse        Warehouse?               @relation("PurchaseAdjustmentWh", fields: [warehouseId], references: [id])
  items            PurchaseAdjustmentItem[]

  @@index([companyCode])
  @@index([originalPurchaseId])
  @@map("purchase_adjustments")
}

model PurchaseAdjustmentItem {
  id                     String               @id @default(cuid())
  adjustmentId           String
  action                 AdjustmentItemAction
  serialNumber           String
  itemId                 String
  originalPurchaseItemId String?
  unitPrice              Decimal              @db.Decimal(15, 2)
  createdAt              DateTime             @default(now())

  adjustment PurchaseAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)

  @@index([serialNumber])
  @@index([originalPurchaseItemId])
  @@map("purchase_adjustment_items")
}

/// IT 계약 변경 — 차후(다음 매출 발생 시) 정책으로 반영.
/// PRICE_CHANGE 의 monthlyDelta 는 effectiveDate 이후 월 매출에 가산/차감.
model ItContractAmendment {

  id               String          @id @default(cuid())
  amendmentCode    String          @unique // AMD-IT-YYMMDD-###
  contractId       String
  type             AmendmentType
  source           AmendmentSource @default(CONTRACT_DETAIL)
  triggeredByTxnId String? // InventoryTransaction.id (경로 B 진입 시)
  effectiveDate    DateTime
  reason           String?
  reasonVi         String?
  reasonEn         String?
  reasonKo         String?
  warehouseId      String?
  monthlyDelta     Decimal?        @db.Decimal(15, 2) // PRICE_CHANGE 차월 매출 차액
  performedAt      DateTime        @default(now())
  performedById    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  contract  ItContract                @relation(fields: [contractId], references: [id])
  warehouse Warehouse?                @relation("ItAmendmentWh", fields: [warehouseId], references: [id])
  items     ItContractAmendmentItem[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([contractId])
  @@index([effectiveDate])
  @@map("it_contract_amendments")
}

model ItContractAmendmentItem {

  id                  String              @id @default(cuid())
  amendmentId         String
  action              AmendmentItemAction
  serialNumber        String
  itemId              String
  originalEquipmentId String?
  monthlyBaseFee      Decimal?            @db.Decimal(15, 2)
  bwIncludedPages     Int?
  bwOverageRate       Decimal?            @db.Decimal(10, 2)
  colorIncludedPages  Int?
  colorOverageRate    Decimal?            @db.Decimal(10, 2)
  manufacturer        String?
  createdAt           DateTime            @default(now())

  amendment ItContractAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([serialNumber])
  @@map("it_contract_amendment_items")
}

/// TM 렌탈 변경 — IT 와 같은 패턴.
model TmRentalAmendment {

  id               String          @id @default(cuid())
  amendmentCode    String          @unique // AMD-TM-YYMMDD-###
  rentalId         String
  type             AmendmentType
  source           AmendmentSource @default(CONTRACT_DETAIL)
  triggeredByTxnId String?
  effectiveDate    DateTime
  reason           String?
  reasonVi         String?
  reasonEn         String?
  reasonKo         String?
  warehouseId      String?
  performedAt      DateTime        @default(now())
  performedById    String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  rental    TmRental                @relation(fields: [rentalId], references: [id])
  warehouse Warehouse?              @relation("TmAmendmentWh", fields: [warehouseId], references: [id])
  items     TmRentalAmendmentItem[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([rentalId])
  @@index([effectiveDate])
  @@map("tm_rental_amendments")
}

model TmRentalAmendmentItem {

  id             String              @id @default(cuid())
  amendmentId    String
  action         AmendmentItemAction
  serialNumber   String
  itemId         String
  originalItemId String? // TmRentalItem.id
  salesPrice     Decimal?            @db.Decimal(15, 2)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime            @default(now())

  amendment TmRentalAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([serialNumber])
  @@map("tm_rental_amendment_items")
}

// ═══════════════════════════════════════════════════════════════
// Phase A — 고객 포탈 확장: 포인트 시스템
// ═══════════════════════════════════════════════════════════════

model PortalPoint {

  id           String      @id @default(cuid())
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
  amount       Int
  reason       PointReason
  reasonDetail String?
  linkedModel  String?
  linkedId     String?
  issuedById   String?
  createdAt    DateTime    @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@index([reason])
  @@index([createdAt])
  @@map("portal_points")
}

enum PointReason {
  AS_REQUEST
  SUPPLIES_REQUEST
  SERVICE_CONFIRM
  USAGE_CONFIRM
  QUOTE_REQUEST
  FEEDBACK_PRAISE
  FEEDBACK_IMPROVE
  FEEDBACK_SUGGEST
  SURVEY_COMPLETE
  POST_WRITE
  POST_READ_BONUS
  REFERRAL_CONTRACT
  ADMIN_GRANT
  ADMIN_DEDUCT
  REWARD_EXCHANGE
}

model PointConfig {

  id        String      @id @default(cuid())
  reason    PointReason @unique
  amount    Int
  isActive  Boolean     @default(true)
  updatedAt DateTime    @updatedAt

  companyCode CompanyCode @default(TV)
  @@index([companyCode])
  @@map("point_configs")
}

model PortalReward {

  id                 String             @id @default(cuid())
  clientId           String
  client             Client             @relation(fields: [clientId], references: [id])
  rewardType         RewardType
  rewardDetail       String?
  pointsUsed         Int
  appliedToInvoiceId String?
  appliedToInvoice   PayableReceivable? @relation("RewardAppliedToInvoice", fields: [appliedToInvoiceId], references: [id])
  status             RewardStatus       @default(PENDING)
  approvedById       String?
  approvedAt         DateTime?
  deliveredAt        DateTime?
  deliveryNote       String?
  createdAt          DateTime           @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@index([status])
  @@map("portal_rewards")
}

enum RewardType {
  INVOICE_DEDUCT
  GIFT_CARD
}

// 거래처별 포인트 사용 정책 — 관리자가 계약 시 설정.
// NONE: 교환 불가 (적립만 가능 — 추후 정책 결정까지 보관)
// INVOICE_DEDUCT_ONLY: 청구액 차감만
// GIFT_CARD_ONLY: 상품권만
// BOTH: 둘 다 선택 가능
enum ClientPointPolicy {
  NONE
  INVOICE_DEDUCT_ONLY
  GIFT_CARD_ONLY
  BOTH
}

enum RewardStatus {
  PENDING
  APPROVED
  DELIVERED
  REJECTED
}

// ═══════════════════════════════════════════════════════════════
// Phase A — 포탈 배너 (사이드바 한 줄 광고)
// ═══════════════════════════════════════════════════════════════

model PortalBanner {

  id        String   @id @default(cuid())
  slot      String   @unique
  textVi    String
  textEn    String
  textKo    String
  linkUrl   String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  companyCode CompanyCode @default(TV)
  @@index([companyCode])
  @@map("portal_banners")
}

// ═══════════════════════════════════════════════════════════════
// Phase B — 견적 요청 (스키마만)
// ═══════════════════════════════════════════════════════════════

model QuoteRequest {
  id               String      @id @default(cuid())
  quoteCode        String      @unique
  clientId         String
  client           Client      @relation(fields: [clientId], references: [id])
  titleVi          String?
  titleEn          String?
  titleKo          String?
  descriptionVi    String?
  descriptionEn    String?
  descriptionKo    String?
  originalLang     String      @default("KO")
  quoteType        QuoteType
  quantity         Int?
  desiredStartDate DateTime?
  desiredEndDate   DateTime?
  attachmentIds    String[]
  assignedToId     String?
  assignedTo       Employee?   @relation("QuoteAssignee", fields: [assignedToId], references: [id])
  assignedAt       DateTime?
  quotedAmount     Decimal?    @db.Decimal(15, 2)
  quotedCurrency   Currency?   @default(VND)
  quotedFileId     String?
  quotedAt         DateTime?
  quotedNote       String?
  status           QuoteStatus @default(REQUESTED)
  companyCode      String
  pointId          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
  @@map("quote_requests")
}

enum QuoteType {
  RENTAL_IT
  RENTAL_TM
  CALIBRATION
  REPAIR
  PURCHASE
  MAINTENANCE
  OTHER
}

enum QuoteStatus {
  REQUESTED
  ASSIGNED
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

// ═══════════════════════════════════════════════════════════════
// Phase B — 의견 (칭찬/개선/제안)
// ═══════════════════════════════════════════════════════════════

model PortalFeedback {

  id               String         @id @default(cuid())
  feedbackCode     String         @unique
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  kind             FeedbackKind
  contentVi        String?
  contentEn        String?
  contentKo        String?
  originalLang     String         @default("KO")
  targetEmployeeId String?
  targetEmployee   Employee?      @relation("FeedbackTarget", fields: [targetEmployeeId], references: [id])
  replyVi          String?
  replyEn          String?
  replyKo          String?
  repliedById      String?
  repliedAt        DateTime?
  status           FeedbackStatus @default(RECEIVED)
  pointId          String?
  createdAt        DateTime       @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([clientId])
  @@index([kind])
  @@map("portal_feedback")
}

enum FeedbackKind {
  PRAISE
  IMPROVE
  SUGGEST
}

enum FeedbackStatus {
  RECEIVED
  REVIEWED
  REPLIED
}

// ═══════════════════════════════════════════════════════════════
// Phase C — CMS 게시판
// ═══════════════════════════════════════════════════════════════

model PortalPost {
  id              String           @id @default(cuid())
  postCode        String           @unique
  category        PostCategory
  titleVi         String?
  titleEn         String?
  titleKo         String?
  bodyVi          String?          @db.Text
  bodyEn          String?          @db.Text
  bodyKo          String?          @db.Text
  originalLang    String           @default("KO")
  thumbnailFileId String?
  authorId        String?
  clientAuthorId  String?
  isPublished     Boolean          @default(false)
  publishedAt     DateTime?
  isPinned        Boolean          @default(false)
  viewCount       Int              @default(0)
  bonusPoints     Int              @default(0)
  isAiGenerated   Boolean          @default(false)
  companyCode     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  views           PortalPostView[]

  @@index([category])
  @@index([isPublished])
  @@map("portal_posts")
}

enum PostCategory {
  MARKETING
  COMPANY_NEWS
  KOREA_NEWS
  VIETNAM_NEWS
  INDUSTRY_NEWS
  TIP
  COMMUNITY
}

model PortalPostView {
  id           String     @id @default(cuid())
  postId       String
  post         PortalPost @relation(fields: [postId], references: [id])
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  viewedAt     DateTime   @default(now())
  pointGranted Boolean    @default(false)

  @@unique([postId, clientId])
  @@map("portal_post_views")
}

// ═══════════════════════════════════════════════════════════════
// Phase C — 서베이
// ═══════════════════════════════════════════════════════════════

model Survey {
  id           String           @id @default(cuid())
  surveyCode   String           @unique
  titleVi      String?
  titleEn      String?
  titleKo      String?
  questions    Json
  startDate    DateTime
  endDate      DateTime
  rewardPoints Int              @default(10000)
  isActive     Boolean          @default(true)
  companyCode  String
  createdAt    DateTime         @default(now())
  responses    SurveyResponse[]

  @@index([isActive])
  @@map("surveys")
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  answers   Json
  pointId   String?
  createdAt DateTime @default(now())

  @@unique([surveyId, clientId])
  @@map("survey_responses")
}

// ═══════════════════════════════════════════════════════════════
// Phase D — 업체 추천
// ═══════════════════════════════════════════════════════════════

model Referral {

  id                  String         @id @default(cuid())
  referralCode        String         @unique
  referrerClientId    String
  referrerClient      Client         @relation("ReferralReferrer", fields: [referrerClientId], references: [id])
  companyName         String
  contactName         String
  contactPhone        String
  contactEmail        String?
  note                String? // legacy 단일 컬럼 (호환용)
  noteVi              String?
  noteEn              String?
  noteKo              String?
  noteOriginalLang    Language?
  status              ReferralStatus @default(SUBMITTED)
  assignedToId        String?
  assignedTo          Employee?      @relation("ReferralAssignee", fields: [assignedToId], references: [id])
  convertedClientId   String?
  convertedContractId String?
  contractPointId     String?
  firstPaymentAt      DateTime?
  createdAt           DateTime       @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@index([referrerClientId])
  @@index([status])
  @@map("referrals")
}

enum ReferralStatus {
  SUBMITTED
  CONTACTED
  MEETING
  CONTRACTED
  PAID
  DECLINED
}

// ═══════════════════════════════════════════════════════════════
// SNMP — 모델별 OID 매핑 (관리자가 신규 모델 추가 가능)
// ═══════════════════════════════════════════════════════════════

model SnmpModelOid {
  id          String   @id @default(cuid())
  deviceModel String   @unique // "SAMSUNG_SCX8123" 등 고유 식별자
  brand       String // Samsung
  modelName   String // SCX-8123
  oidTotal    String // 총 페이지 OID (대부분 표준 prtMarkerLifeCount)
  oidBw       String? // 흑백 OID. null 이면 oidTotal 을 흑백으로 간주
  oidColor    String? // 컬러 OID. null = 흑백 전용
  oidSerial   String? // S/N 자동감지 OID (1.3.6.1.2.1.43.5.1.1.17.1)
  isMonoOnly  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("snmp_model_oids")
}

// ═══════════════════════════════════════════════════════════════
// SNMP — 카운터 수집 이력 (에이전트 PUSH 또는 수동 입력)
// ═══════════════════════════════════════════════════════════════

model SnmpReading {
  id          String              @id @default(cuid())
  equipmentId String
  equipment   ItContractEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  contractId  String
  contract    ItContract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientId    String

  // 수집 데이터
  brand        String
  itemName     String
  serialNumber String
  totalPages   Int
  bwPages      Int? // null 이면 = totalPages (흑백 전용)
  colorPages   Int? // null = 컬러 없음

  // 수집 메타
  collectedAt    DateTime
  collectedBy    String // "AGENT" | "MANUAL"
  deviceIp       String?
  agentVersion   String?
  agentMachineId String? // PC 식별자 (DPAPI 머신 키 hash)

  // 카운터 리셋 / 음수 처리
  isCounterReset Boolean @default(false)

  // 처리
  billingId   String?
  companyCode String
  createdAt   DateTime @default(now())

  @@unique([equipmentId, collectedAt]) // 멱등성 — 중복 전송 자동 차단
  @@index([equipmentId])
  @@index([contractId])
  @@index([collectedAt])
  @@map("snmp_readings")
}

// ═══════════════════════════════════════════════════════════════
// SNMP — 사용량 확인서 (월별 청구 워크플로)
// ═══════════════════════════════════════════════════════════════

model UsageConfirmation {
  id          String     @id @default(cuid())
  confirmCode String     @unique // UC-YYMMDD-###
  contractId  String
  contract    ItContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id])

  billingMonth String // "2026-05"
  periodStart  DateTime
  periodEnd    DateTime

  // 장비별 사용량 (JSON 배열) — 자동 계산 결과
  equipmentUsage Json

  totalAmount Decimal  @db.Decimal(15, 2)
  currency    Currency @default(VND)

  // 고객 CFM
  customerConfirmedAt DateTime?
  customerSignature   String?   @db.Text
  customerNote        String?

  // 관리자 CFM
  adminConfirmedAt   DateTime?
  adminConfirmedById String?

  // PDF
  pdfFileId String?

  // 매출 전표 연결
  salesId String?

  status      UsageConfirmStatus @default(COLLECTED)
  companyCode String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([contractId])
  @@index([clientId])
  @@index([billingMonth])
  @@index([status])
  @@map("usage_confirmations")
}

enum UsageConfirmStatus {
  COLLECTED
  CUSTOMER_NOTIFIED
  CUSTOMER_CONFIRMED
  ADMIN_CONFIRMED
  PDF_GENERATED
  BILLED
}

// ═══════════════════════════════════════════════════════════════
// SNMP — 에이전트 heartbeat (운영 모니터링)
// ═══════════════════════════════════════════════════════════════

model AgentHeartbeat {

  id             String     @id @default(cuid())
  contractId     String
  contract       ItContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reportedAt     DateTime   @default(now())
  agentVersion   String
  agentMachineId String?
  scannedDevices Int        @default(0)
  successCount   Int        @default(0)
  errorMessages  String[]

  companyCode CompanyCode @default(TV)
  @@index([companyCode])
  @@index([contractId, reportedAt])
  @@map("agent_heartbeats")
}

// ═══════════════════════════════════════════════════════════════
// SNMP — 에이전트가 발견한 미등록 장비 큐 (관리자 검토 대기)
// ═══════════════════════════════════════════════════════════════

model SnmpUnregisteredDevice {

  id             String     @id @default(cuid())
  contractId     String
  contract       ItContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  ip             String
  serialNumber   String?
  brand          String?
  modelName      String?
  sysDescription String?    @db.Text
  totalPages     Int?
  firstSeenAt    DateTime   @default(now())
  lastSeenAt     DateTime   @default(now())
  status         String     @default("PENDING") // PENDING / IGNORED / REGISTERED

  companyCode CompanyCode @default(TV)
  @@index([companyCode])
  @@index([contractId, status])
  @@map("snmp_unregistered_devices")
}

// ═══════════════════════════════════════════════════════════════
// 소모품 적정율 분석 (Yield Analysis) — 토너/드럼 투입 vs 실제 출력
// ═══════════════════════════════════════════════════════════════

enum YieldBadge {
  BLUE // 120% 이상 — 토너 부족 (재발주)
  GREEN // 80~120% — 정상
  YELLOW // 50~79% — 주의
  ORANGE // 30~49% — 경고
  RED // 30% 미만 — 부정 의심
}

model YieldAnalysis {
  id          String              @id @default(cuid())
  // 대상
  equipmentId String
  equipment   ItContractEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  contractId  String
  contract    ItContract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientId    String

  // 분석 기간
  periodStart DateTime
  periodEnd   DateTime

  // SNMP 기반 실제 출력량
  actualPagesBw    Int
  actualPagesColor Int @default(0)

  // 소모품 투입 상세 ([{itemId, itemName, quantity, expectedYield, yieldCoverageBase, contributedExpectedPages}, ...])
  consumablesUsed Json

  // 분석 시점의 고객 상밀도 (%)
  actualCoverage Int

  // 기대 출력량 (공식 적용 후)
  expectedPagesBw    Int
  expectedPagesColor Int @default(0)

  // 적정율 (%, 소수 1)
  yieldRateBw    Decimal  @db.Decimal(5, 1)
  yieldRateColor Decimal? @db.Decimal(5, 1)

  // 뱃지
  badgeBw    YieldBadge
  badgeColor YieldBadge?

  // 부정 감지
  isFraudSuspect    Boolean   @default(false)
  fraudNote         String?
  fraudReviewedById String?
  fraudReviewedAt   DateTime?

  // 메타
  calculatedById String? // 'SYSTEM' (cron) 또는 사용자 id
  companyCode    String
  createdAt      DateTime @default(now())

  @@index([equipmentId])
  @@index([contractId])
  @@index([clientId])
  @@index([isFraudSuspect])
  @@index([badgeBw])
  @@index([periodStart, periodEnd])
  @@map("yield_analyses")
}

// 단일 row (id="default") — 관리자 임계값 설정
model YieldConfig {

  id                  String   @id @default(cuid())
  thresholdBlue       Int      @default(120)
  thresholdGreen      Int      @default(80)
  thresholdYellow     Int      @default(50)
  thresholdOrange     Int      @default(30)
  fraudAlertThreshold Int      @default(30)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  companyCode CompanyCode @default(TV)
  @@index([companyCode, createdAt])
  @@map("yield_configs")
}

// ==================================================
// Layer 1 — 자금관리 (BankAccount + CashTransaction)
// ==================================================

model BankAccount {
  id              String           @id @default(cuid())
  accountCode     String           @unique // ACC-001
  accountName     String
  bankName        String
  accountNumber   String
  currency        Currency         @default(VND)
  accountType     BankAccountType
  openingBalance  Decimal          @db.Decimal(15, 2)
  openingDate     DateTime
  currentBalance  Decimal?         @db.Decimal(15, 2) // 캐시 — 트랜잭션 내 동기 갱신
  isActive        Boolean          @default(true)
  branchCode      BranchType?
  companyCode     CompanyCode      @default(TV)
  note            String?

  // 자금 부족 알림 임계값
  lowBalanceThreshold Decimal?     @db.Decimal(15, 2)

  cashTransactions     CashTransaction[]            @relation("BankAccountTxns")
  cashCounterAccountTx CashTransaction[]            @relation("BankAccountCounter")
  monthlySnapshots     BankAccountMonthlySnapshot[]
  payrolls             Payroll[]                    @relation("PayrollAccount")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([companyCode, isActive])
  @@map("bank_accounts")
}

enum BankAccountType {
  CHECKING
  SAVINGS
  CASH
  OTHER
}

model CashTransaction {
  id            String       @id @default(cuid())
  txnCode       String       @unique // CT-YYMMDD-###
  txnDate       DateTime
  txnType       CashTxnType

  amount        Decimal      @db.Decimal(15, 2)
  currency      Currency     @default(VND)
  exchangeRate  Decimal      @default(1) @db.Decimal(10, 4)
  amountLocal   Decimal      @db.Decimal(15, 2) // VND 환산액

  accountId         String
  account           BankAccount @relation("BankAccountTxns", fields: [accountId], references: [id])
  counterAccountId  String?
  counterAccount    BankAccount? @relation("BankAccountCounter", fields: [counterAccountId], references: [id])

  category      CashCategory

  // 연결 FK — 한 행에 1개만 채움 (코드 레벨 검증)
  prId           String?
  pr             PayableReceivable? @relation("PrCashTx", fields: [prId], references: [id])
  expenseId      String?
  expense        Expense?           @relation("ExpenseCashTx", fields: [expenseId], references: [id])
  payrollId      String?
  payroll        Payroll?           @relation("PayrollCashTx")
  expenseReimburse Expense[]        @relation("ExpenseReimburseTx")
  salesId        String?
  sales          Sales?             @relation("SalesCashTx", fields: [salesId], references: [id])
  purchaseId     String?
  purchase       Purchase?          @relation("PurchaseCashTx", fields: [purchaseId], references: [id])
  transferPairId String?            // 이체 쌍
  transferPair   CashTransaction?   @relation("TransferPair", fields: [transferPairId], references: [id])
  transferOf     CashTransaction[]  @relation("TransferPair")

  status         CashTxnStatus @default(DRAFT)
  confirmedById  String?
  confirmedAt    DateTime?

  description    String
  clientId       String?
  client         Client? @relation("CashTxnClient", fields: [clientId], references: [id])
  employeeId     String?
  companyCode    CompanyCode @default(TV)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lockedAt       DateTime?
  lockReason     String?

  @@index([companyCode, txnDate])
  @@index([accountId, txnDate])
  @@index([prId])
  @@index([expenseId])
  @@index([category])
  @@index([status])
  @@map("cash_transactions")
}

enum CashTxnType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}

enum CashCategory {
  RECEIVABLE_COLLECTION
  PAYABLE_PAYMENT
  SALARY
  TAX
  EXPENSE
  REVENUE_OTHER
  TRANSFER
  LOAN_IN
  LOAN_OUT
  REIMBURSEMENT
  OTHER
}

enum CashTxnStatus {
  DRAFT
  CONFIRMED
  VOIDED
}

model BankAccountMonthlySnapshot {
  id             String    @id @default(cuid())
  accountId      String
  account        BankAccount @relation(fields: [accountId], references: [id])
  yearMonth      String      // "YYYY-MM"
  openingBalance Decimal   @db.Decimal(15, 2)
  totalIn        Decimal   @db.Decimal(15, 2)
  totalOut       Decimal   @db.Decimal(15, 2)
  closingBalance Decimal   @db.Decimal(15, 2)
  companyCode    CompanyCode @default(TV)
  createdAt      DateTime  @default(now())

  @@unique([companyCode, accountId, yearMonth])
  @@index([companyCode, yearMonth])
  @@map("bank_account_monthly_snapshots")
}

// ==================================================
// Layer 2 — 비용/원가 관리 (CostCenter + AllocationRule + Budget)
// ==================================================

model CostCenter {
  id           String            @id @default(cuid())
  code         String            // CC-SALES-HN
  name         String            // "HN 영업팀"
  centerType   CostCenterType
  departmentId String?
  branchCode   BranchType?
  projectType  String?           // "RENTAL_IT" / "RENTAL_TM" / "REPAIR" / "CALIB"
  isActive     Boolean           @default(true)
  companyCode  CompanyCode       @default(TV)

  allocations  ExpenseAllocation[] @relation("ExpenseAllocCostCenter")
  budgets      Budget[]
  rules        AllocationRule[]    @relation("RuleCostCenter")

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  @@unique([companyCode, code])
  @@index([companyCode, isActive])
  @@index([centerType])
  @@map("cost_centers")
}

enum CostCenterType {
  DEPARTMENT
  BRANCH
  PROJECT
}

model AllocationRule {
  id            String           @id @default(cuid())
  name          String           // "간접비 매출비율 배분"
  ruleType      AllocationType
  costCenterId  String?          // 특정 센터 적용; null = 전사
  costCenter    CostCenter?      @relation("RuleCostCenter", fields: [costCenterId], references: [id])
  basis         AllocationBasis
  isActive      Boolean          @default(true)
  companyCode   CompanyCode      @default(TV)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyCode, isActive])
  @@index([costCenterId])
  @@map("allocation_rules")
}

enum AllocationType {
  DIRECT
  INDIRECT
  COMMON
}

// AllocationBasis 는 기존 enum (QUANTITY/AMOUNT) — Layer 2 에서 의미 확장:
//  REVENUE_RATIO / HEADCOUNT_RATIO / EQUAL / CUSTOM 추가 (아래)
// 기존 enum AllocationBasis 가 prisma 에 이미 존재 — 그대로 사용하되, 신규 값은 별도 enum 으로 분리하여 호환성 유지.
enum AllocationBasisV2 {
  REVENUE_RATIO
  HEADCOUNT_RATIO
  EQUAL
  CUSTOM
}

model Budget {
  id            String      @id @default(cuid())
  costCenterId  String
  costCenter    CostCenter  @relation(fields: [costCenterId], references: [id])
  yearMonth     String      // "2026-05"
  budgetAmount  Decimal     @db.Decimal(15, 2)
  actualAmount  Decimal?    @db.Decimal(15, 2) // 월말 자동 집계
  variance      Decimal?    @db.Decimal(15, 2) // budget - actual
  companyCode   CompanyCode @default(TV)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([costCenterId, yearMonth])
  @@index([companyCode, yearMonth])
  @@map("budgets")
}
