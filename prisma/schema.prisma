// Tellustech ERP — Prisma Schema (Phase 1-2 v0.1)
//
// 출처: docs/CLAUDE_CODE_개발시작가이드.md 의 "DB 테이블 (44개)" 섹션.
// 가이드 헤더는 44이지만 세부 목록상 licenses 포함 45개 — 모두 포함.
// 규칙(CLAUDE.md):
//   - 회사코드(company_code): TV | VR. 세션 단위로 고정, 자동 WHERE 주입.
//   - 공유 마스터(company_code 없음): Client, Item, Warehouse 만.
//   - 그 외 업무 데이터는 company_code 필수. (가이드에서 "회사없음"으로 명시된 테이블 — it_contracts, tm_rentals, calibrations, as_tickets, sales, purchases, expenses — 은 거래처/계약 기반이므로 company_code 없음)
//   - 자유서술 필드는 contentVi / contentEn / contentKo + originalLang 4필드 구조.
//
// Phase 1-2에서 docs/db/ 의 상세 필드 정의서(.docx)와 대조하여 필드·인덱스를 보강할 것.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================================================
// Enums
// ==================================================

enum CompanyCode {
  TV
  VR
}

enum BranchType {
  BN // Bac Ninh (본사)
  HN // Ha Noi
  HCM // Ho Chi Minh
  NT // Nha Trang
  DN // Da Nang
}

enum Language {
  VI
  EN
  KO
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
  TECH
  CALIBRATION
  ACCOUNTING
  HR
  CLIENT // 고객 포탈
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum ItemType {
  PRODUCT // 상품
  CONSUMABLE // 소모품
  PART // 부품
}

enum WarehouseType {
  INTERNAL // 내부
  EXTERNAL // 외부
  CLIENT // 고객
}

enum ClientGrade {
  A
  B
  C
  D
}

enum ReceivableStatus {
  NORMAL
  WARNING
  BLOCKED // 미수금 차단
}

enum RentalType {
  IT
  TM
}

enum StockCheckMode {
  STRICT // IT렌탈 — 자사 재고 필수
  LOOSE // TM렌탈/교정/AS/매출/매입 — 경고만
}

/// 거래처 업종 — 프로토타입 P1 의 고정 선택지 유지.
enum Industry {
  MANUFACTURING
  LOGISTICS
  EDUCATION
  IT
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELED
}

enum BillingMethod {
  SNMP
  MANUAL
  PHOTO
}

enum InventoryTxnType {
  IN
  OUT
  TRANSFER
}

enum InventoryReason {
  // IN 사유
  PURCHASE       // 매입
  RETURN_IN      // 반품입고
  OTHER_IN       // 기타입고
  // OUT 사유
  SALE           // 매출
  CONSUMABLE_OUT // 소모품출고 (IT 장비 대상)
  // TRANSFER 사유
  CALIBRATION
  REPAIR
  RENTAL
  DEMO
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum ASStatus {
  RECEIVED
  IN_PROGRESS
  DISPATCHED
  COMPLETED
  CANCELED
}

enum IncidentType {
  PRAISE
  IMPROVEMENT
}

enum EvaluationGrade {
  A
  B
  C
  D
}

enum LeaveType {
  LT // 연차
  P // 병가
  KSX // 결근
  CT7 // 출장
  DB // (기획서 원문 코드 유지)
  TS // 시용
  KL // 결혼
  X // 기타
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseType {
  PURCHASE
  SALES
  GENERAL
  TRANSPORT       // 교통비
  MEAL            // 식대
  ENTERTAINMENT   // 접대비
  RENT            // 임대료
  UTILITY         // 공과금
  OTHER           // 기타
}

enum InventoryStatus {
  NORMAL
  NEEDS_REPAIR
  PARTS_USED
  IRREPARABLE
}

enum AllocationBasis {
  QUANTITY
  AMOUNT
}

enum PayableReceivableKind {
  PAYABLE
  RECEIVABLE
}

enum PayableReceivableStatus {
  OPEN
  PARTIAL
  PAID
  WRITTEN_OFF
}

enum NotificationType {
  STOCK_LOW
  AS_NEW
  CONTRACT_EXPIRING
  CALIBRATION_DUE
  RECEIVABLE_OVERDUE
  SCHEDULE_DUE
  LICENSE_EXPIRING
  OTHER
}

enum FileCategory {
  PDF
  PHOTO
  SIGNATURE
  RECEIPT
  OTHER
}

enum ScheduleConfirmStatus {
  ON_TIME
  LATE
}

enum OnboardingOffboardingStatus {
  DRAFT
  SUBMITTED
  COMPLETED
}

enum ChatRoomType {
  DIRECT // 1:1
  GROUP
}

// 프로젝트(매출·매입) 분류. TRADE 만 재고 영향, 나머지는 S/N만 기록.
enum SalesType {
  TRADE // 판매/구매 — 재고 영향
  MAINTENANCE // 유지보수 — 기간 표시
  RENTAL // 렌탈 — 기간 표시
  CALIBRATION // 교정 — 라인별 성적서
  REPAIR // 수리
  OTHER // 기타
}

// 거래 통화. VND 가 회계 본위 통화(fxRate=1). 외화 거래는 입력 시점 환율을 함께 보관.
enum Currency {
  VND
  USD
  KRW
  JPY
  CNY
}

// ─── Adjustment / Amendment 공통 ──────────────────────────────────────
// 사후조정(Adjustment)은 매출/매입 발생 후의 반품·교환·금액조정.
// 계약변경(Amendment)은 IT/TM 계약의 장비 추가/제거/교체/단가변경/해지.
enum AdjustmentType {
  RETURN_FULL
  RETURN_PARTIAL
  EXCHANGE_FULL
  EXCHANGE_PARTIAL
  PRICE_ADJUST
}

enum AdjustmentItemAction {
  RETURN
  EXCHANGE_OUT // sales 의 경우 새 출고
  EXCHANGE_IN  // purchase 의 경우 새 입고
}

enum AmendmentType {
  REMOVE_EQUIPMENT
  ADD_EQUIPMENT
  REPLACE_EQUIPMENT
  PRICE_CHANGE
  TERMINATE
}

enum AmendmentItemAction {
  REMOVE
  ADD
  REPLACE_OUT
  REPLACE_IN
}

enum AmendmentSource {
  CONTRACT_DETAIL
  INVENTORY_TXN
}

// ==================================================
// 기초등록 (7)
// ==================================================

model Department {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  code        String
  name        String
  branchType  BranchType
  managerId   String?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime    @updatedAt

  manager           Employee?           @relation("DepartmentManager", fields: [managerId], references: [id])
  employees         Employee[]          @relation("DepartmentMembers")
  expenseAllocations ExpenseAllocation[] @relation("ExpenseAllocDept")

  @@unique([companyCode, code])
  @@index([companyCode])
  @@map("departments")
}

// NOTE: Employee gets lockedAt/lockReason via the post-add (퇴사 후 잠금 정책).
model Employee {
  id              String         @id @default(cuid())
  companyCode     CompanyCode
  employeeCode    String // TNV-### (TV) / VNV-### (VR)
  departmentId    String?
  nameVi          String
  nameEn          String?
  nameKo          String?
  position        String?
  email           String?
  phone           String?
  photoUrl        String?
  idCardNumber    String?
  idCardPhotoUrl  String?
  salary          Decimal?       @db.Decimal(15, 2)
  insuranceNumber String?
  contractType    String?
  contractStart   DateTime?
  contractEnd     DateTime?
  hireDate        DateTime?
  birthDate       DateTime? // 캘린더 생일 표시용
  status          EmployeeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt       DateTime       @updatedAt

  department         Department?            @relation("DepartmentMembers", fields: [departmentId], references: [id])
  departmentsManaged Department[]           @relation("DepartmentManager")
  user               User?
  payrolls           Payroll[]
  incentives         Incentive[]
  leaveRecords       LeaveRecord[]
  incidentsWritten   Incident[]             @relation("IncidentAuthor")
  incidentsReceived  Incident[]             @relation("IncidentSubject")
  peerReviewsGiven   PeerReview[]           @relation("PeerReviewReviewer")
  peerReviewsGot     PeerReview[]           @relation("PeerReviewSubject")
  evaluationsOf      Evaluation[]           @relation("EvaluationSubject")
  regularEvalsGiven  RegularEvaluation[]    @relation("RegularEvalReviewer")
  regularEvalsGot    RegularEvaluation[]    @relation("RegularEvalSubject")
  onboarding         OnboardingCard?
  offboarding        OffboardingCard?
  asTicketsAssigned  AsTicket[]             @relation("AsAssignee")
  asDispatches       AsDispatch[]           @relation("DispatchEmployee")
  scheduleTargets    Schedule[]             @relation("ScheduleTargets")
  scheduleReports    Schedule[]             @relation("ScheduleReporters")
  scheduleConfirms   ScheduleConfirmation[]
  licensesOwned      License[]
  clientsReferred    Client[]               @relation("EmployeeReferredClients")
  clientsSalesPic    Client[]               @relation("EmployeeSalesPicClients")
  weeklyBacklogsAsSales WeeklyBacklog[]    @relation("BacklogSalesEmployee")
  weeklyTasksWritten WeeklyTask[]           @relation("TaskWriter")
  weeklyTasksAssigned WeeklyTask[]          @relation("TaskAssignee")
  calendarEvents     CalendarEvent[]

  @@unique([companyCode, employeeCode])
  @@index([companyCode])
  @@index([departmentId])
  @@map("employees")
}

/// 공유 마스터 — company_code 없음
model Client {
  id                  String           @id @default(cuid())
  clientCode          String           @unique
  companyNameVi       String
  companyNameEn       String?
  companyNameKo       String?
  representative      String? // 대표자
  taxCode             String?
  businessLicenseNo   String?
  industry            Industry?
  bankAccountNumber   String?
  bankName            String?
  bankHolder          String? // 예금주
  paymentTerms        Int? // 결제조건 (일). null = 30일 기본으로 해석
  address             String?
  phone               String?
  email               String?
  emailConsent        Boolean          @default(false) // 마케팅 이메일 수신 동의
  leadSource          String?
  referrerId          String? // 거래처가 다른 거래처 소개 (referrerClientId 의미)
  referrerEmployeeId  String? // 내부 직원이 소개한 경우
  salesPicId          String? // 영업담당 직원 (sales PIC)
  grade               ClientGrade?
  marketingTags       String[] // groupTags 와 동일 의미
  receivableStatus    ReceivableStatus @default(NORMAL)
  notes               String?
  createdAt           DateTime         @default(now())
  deletedAt   DateTime?
  updatedAt           DateTime         @updatedAt

  referrer         Client?             @relation("ClientReferrer", fields: [referrerId], references: [id])
  referrals        Client[]            @relation("ClientReferrer")
  referrerEmployee Employee?           @relation("EmployeeReferredClients", fields: [referrerEmployeeId], references: [id])
  salesPic         Employee?           @relation("EmployeeSalesPicClients", fields: [salesPicId], references: [id])
  contacts         ClientContact[]
  portalUser       User?               @relation("ClientPortalUser")
  itContracts      ItContract[]
  tmRentals        TmRental[]
  asTickets        AsTicket[]
  sales            Sales[]
  purchases        Purchase[]
  campaigns        MarketingCampaign[] @relation("CampaignClient")
  inventoryTxns    InventoryTransaction[] @relation("InventoryTxnClient")
  weeklyBacklogs   WeeklyBacklog[]

  @@index([referrerEmployeeId])
  @@index([salesPicId])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

/// 공유 마스터 — company_code 없음. 품목명은 영어로만 관리.
model Item {
  id            String   @id @default(cuid())
  itemCode      String   @unique
  itemType      ItemType
  name          String // 품목명 — 영어로만 입력
  unit          String?
  category      String?
  reorderPoint  Int? // 재고부족 알림 임계치 — null 이면 알림 없음(소모품 계열에서만 의미)
  createdAt     DateTime @default(now())
  deletedAt   DateTime?
  updatedAt     DateTime @updatedAt

  inventoryStocks       InventoryStock[]
  inventoryTransactions InventoryTransaction[]
  assetDepreciations    AssetDepreciation[]
  salesItems            SalesItem[]
  purchaseItems         PurchaseItem[]
  tmRentalItems         TmRentalItem[]
  itContractEquipment   ItContractEquipment[]
  dispatchParts         AsDispatchPart[]
  inventoryItems        InventoryItem[]

  @@map("items")
}

/// S/N 단위 재고 마스터 — 상태/QR/이력 관리
model InventoryItem {
  id                String          @id @default(cuid())
  itemId            String
  item              Item            @relation(fields: [itemId], references: [id])
  serialNumber      String          @unique
  warehouseId       String
  warehouse         Warehouse       @relation("InventoryItemWarehouse", fields: [warehouseId], references: [id])
  companyCode       CompanyCode

  status            InventoryStatus @default(NORMAL)
  qrData            String?
  acquiredAt        DateTime?
  lastStatusChange  DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  remarks           InventoryRemark[]

  @@index([warehouseId])
  @@index([itemId])
  @@index([status])
  @@index([companyCode])
  @@map("inventory_items")
}

model InventoryRemark {
  id                String        @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  date              DateTime      @default(now())
  contentVi         String?
  contentEn         String?
  contentKo         String?
  originalLang      String        @default("VI")

  writtenById       String?
  createdAt         DateTime      @default(now())

  @@index([inventoryItemId])
  @@map("inventory_remarks")
}

/// 공유 마스터 — company_code 없음
model Warehouse {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  warehouseType WarehouseType
  branchType    BranchType?
  location      String?
  createdAt     DateTime      @default(now())
  deletedAt   DateTime?
  updatedAt     DateTime      @updatedAt

  inventoryStocks         InventoryStock[]
  inventoryTransactionsFrom InventoryTransaction[] @relation("FromWarehouse")
  inventoryTransactionsTo   InventoryTransaction[] @relation("ToWarehouse")
  inventoryItems            InventoryItem[]        @relation("InventoryItemWarehouse")
  salesAdjustments          SalesAdjustment[]      @relation("SalesAdjustmentWh")
  purchaseAdjustments       PurchaseAdjustment[]   @relation("PurchaseAdjustmentWh")
  itAmendments              ItContractAmendment[]  @relation("ItAmendmentWh")
  tmAmendments              TmRentalAmendment[]    @relation("TmAmendmentWh")

  @@map("warehouses")
}

model Project {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  projectCode String
  name        String
  salesType   SalesType
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime    @updatedAt

  sales              Sales[]
  purchases          Purchase[]
  expenseAllocations ExpenseAllocation[] @relation("ExpenseAllocProject")

  @@unique([companyCode, projectCode])
  @@index([companyCode])
  @@map("projects")
}

// ==================================================
// 렌탈 + IT계약 (4)
// ==================================================

/// 가이드: "회사코드 없음(거래처 기반)"
model ItContract {
  id                   String         @id @default(cuid())
  contractNumber       String         @unique // TLS-/VRT-YYMMDD-###
  clientId             String
  installationAddress  String?
  status               ContractStatus @default(DRAFT)
  startDate            DateTime
  endDate              DateTime
  deposit              Decimal?       @db.Decimal(15, 2)
  installationFee      Decimal?       @db.Decimal(15, 2)
  deliveryFee          Decimal?       @db.Decimal(15, 2)
  additionalServiceFee Decimal?       @db.Decimal(15, 2)
  currency             Currency       @default(VND)
  fxRate               Decimal        @default(1) @db.Decimal(15, 6)
  // 담당자 3종 (이름 / HP / Office / Email)
  contractMgrName      String?
  contractMgrPhone     String?
  contractMgrOffice    String?
  contractMgrEmail     String?
  technicalMgrName     String?
  technicalMgrPhone    String?
  technicalMgrOffice   String?
  technicalMgrEmail    String?
  financeMgrName       String?
  financeMgrPhone      String?
  financeMgrOffice     String?
  financeMgrEmail      String?
  createdAt            DateTime       @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt            DateTime       @updatedAt

  client          Client                @relation(fields: [clientId], references: [id])
  monthlyBillings ItMonthlyBilling[]
  rentalOrders    RentalOrder[]
  equipment       ItContractEquipment[]
  amendments      ItContractAmendment[]

  @@index([clientId])
  @@index([status])
  @@map("it_contracts")
}

/// IT계약의 장비 목록 (복수 S/N + 과금조건).
/// 하나의 IT계약에 수백 개까지 등록 가능. S/N 은 계약 내에서 유일.
model ItContractEquipment {
  id                 String   @id @default(cuid())
  itContractId       String
  itemId             String
  serialNumber       String
  manufacturer       String?
  installedAt        DateTime?
  removedAt          DateTime?
  monthlyBaseFee     Decimal? @db.Decimal(15, 2)
  bwIncludedPages    Int?
  bwOverageRate      Decimal? @db.Decimal(10, 2)
  colorIncludedPages Int?
  colorOverageRate   Decimal? @db.Decimal(10, 2)
  // SNMP 자동수집용 — IP 와 모델. 둘 다 null 이면 mock fallback.
  deviceIp           String?
  deviceModel        String?
  note               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  itContract ItContract @relation(fields: [itContractId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@unique([itContractId, serialNumber])
  @@index([itContractId])
  @@index([itemId])
  @@index([serialNumber])
  @@map("it_contract_equipment")
}

model ItMonthlyBilling {
  id                String        @id @default(cuid())
  itContractId      String
  billingMonth      DateTime // 첫째 날 기준
  serialNumber      String
  counterBw         Int? // 흑백 카운터
  counterColor      Int? // 컬러 카운터
  billingMethod     BillingMethod
  photoUrl          String?
  customerSignature String? // 전자서명 base64 또는 파일참조
  yieldVerified     Boolean       @default(false)
  computedAmount    Decimal?      @db.Decimal(15, 2)
  createdAt         DateTime      @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt         DateTime      @updatedAt

  itContract ItContract @relation(fields: [itContractId], references: [id], onDelete: Cascade)

  @@unique([itContractId, serialNumber, billingMonth])
  @@index([itContractId])
  @@index([billingMonth])
  @@map("it_monthly_billing")
}

/// 가이드: "매출정보 먼저 + S/N별 매입정보 + 이익자동계산"
model TmRental {
  id                String   @id @default(cuid())
  rentalCode        String   @unique // TM-YYMMDD-###
  clientId          String
  contractNumber    String?
  address           String?
  // 담당자 3종
  contractMgrName   String?
  contractMgrPhone  String?
  contractMgrEmail  String?
  technicalMgrName  String?
  technicalMgrPhone String?
  technicalMgrEmail String?
  financeMgrName    String?
  financeMgrPhone   String?
  financeMgrEmail   String?
  startDate         DateTime
  endDate           DateTime
  currency          Currency @default(VND)
  fxRate            Decimal  @default(1) @db.Decimal(15, 6)
  createdAt         DateTime @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt         DateTime @updatedAt

  client     Client              @relation(fields: [clientId], references: [id])
  items      TmRentalItem[]
  amendments TmRentalAmendment[]

  @@index([clientId])
  @@map("tm_rentals")
}

/// TmRental의 품목세트 행 (수백 개 + 엑셀 업로드)
/// 매출 먼저 + S/N별 매입(매입처/매입금액/커미션) + 이익자동계산
model TmRentalItem {
  id            String   @id @default(cuid())
  tmRentalId    String
  itemId        String
  options       String?
  serialNumber  String
  startDate     DateTime
  endDate       DateTime
  salesPrice    Decimal  @db.Decimal(15, 2)
  supplierName  String?
  purchasePrice Decimal? @db.Decimal(15, 2)
  commission    Decimal? @db.Decimal(15, 2)
  profit        Decimal? @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tmRental         TmRental    @relation(fields: [tmRentalId], references: [id], onDelete: Cascade)
  item             Item        @relation(fields: [itemId], references: [id])
  reflectedInSales SalesItem[] @relation("TmRentalSalesItemSource")

  @@index([tmRentalId])
  @@index([itemId])
  @@index([serialNumber])
  @@map("tm_rental_items")
}

model RentalOrder {
  id           String      @id @default(cuid())
  companyCode  CompanyCode
  itContractId String?
  rentalType   RentalType
  billingMonth DateTime // 월별 자동 복사
  amount       Decimal     @db.Decimal(15, 2)
  editable     Boolean     @default(true)
  canceled     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  itContract ItContract? @relation(fields: [itContractId], references: [id])

  @@index([companyCode, billingMonth])
  @@index([itContractId])
  @@map("rental_orders")
}

// ==================================================
// 재고 + 감가상각 (3)
// ==================================================

model InventoryStock {
  id            String      @id @default(cuid())
  companyCode   CompanyCode
  itemId        String
  warehouseId   String
  branchType    BranchType
  month         DateTime // 월 단위 스냅샷 (첫째 날)
  quantity      Int         @default(0)
  serialNumbers String[] // S/N 목록 (자산 추적용)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([companyCode, itemId, warehouseId, month])
  @@index([companyCode, branchType])
  @@map("inventory_stock")
}

model InventoryTransaction {
  id               String           @id @default(cuid())
  companyCode      CompanyCode
  itemId           String
  fromWarehouseId  String?          // 출고창고 (IN 시 null, OUT/TRANSFER 시 필수)
  toWarehouseId    String?          // 입고창고 (OUT 시 null 가능, IN/TRANSFER 시 필수)
  clientId         String?          // External 창고 연관 고객
  serialNumber     String?
  txnType          InventoryTxnType
  reason           InventoryReason
  quantity         Int
  scannedBarcode   String?
  note             String?
  performedById    String?
  performedAt      DateTime         @default(now())
  // 소모품출고 시 대상 장비 추적
  targetEquipmentSN String?
  targetContractId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  item          Item       @relation(fields: [itemId], references: [id])
  fromWarehouse Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  client        Client?    @relation("InventoryTxnClient", fields: [clientId], references: [id])
  dispatchPart  AsDispatchPart? @relation("DispatchPartTxn")

  @@index([companyCode, performedAt])
  @@index([serialNumber])
  @@index([targetEquipmentSN])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("inventory_transactions")
}

model AssetDepreciation {
  id                 String             @id @default(cuid())
  companyCode        CompanyCode
  itemId             String
  serialNumber       String
  acquisitionDate    DateTime
  acquisitionCost    Decimal            @db.Decimal(15, 2)
  method             DepreciationMethod
  usefulLifeMonths   Int
  month              DateTime // 월별 기록
  depreciationAmount Decimal            @db.Decimal(15, 2)
  bookValue          Decimal            @db.Decimal(15, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  item Item @relation(fields: [itemId], references: [id])

  @@unique([companyCode, serialNumber, month])
  @@index([companyCode])
  @@map("asset_depreciation")
}

// 교정 모듈 제거됨 — Sales/Purchase 에 projectType=CALIBRATION 으로 편입.

// ==================================================
// AS + 출동 (2)
// ==================================================

model AsTicket {
  id                String    @id @default(cuid())
  ticketNumber      String    @unique // YY/MM/DD-##
  clientId          String
  assignedToId      String?
  itemId            String?
  serialNumber      String?
  status            ASStatus  @default(RECEIVED)
  receivedAt        DateTime  @default(now())
  completedAt       DateTime?
  // 증상(자유서술 AI 번역)
  symptomVi         String?
  symptomEn         String?
  symptomKo         String?
  originalLang      Language?
  receivableBlocked Boolean   @default(false) // 미수금 차단 자동 확인
  createdAt         DateTime  @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt         DateTime  @updatedAt

  client     Client       @relation(fields: [clientId], references: [id])
  assignedTo Employee?    @relation("AsAssignee", fields: [assignedToId], references: [id])
  dispatches AsDispatch[]
  photos     File[]       @relation("AsTicketPhotos")

  @@index([clientId])
  @@index([status])
  @@index([serialNumber])
  @@map("as_tickets")
}

model AsDispatch {
  id                 String    @id @default(cuid())
  asTicketId         String
  dispatchEmployeeId String?
  transportMethod    String? // 출동수단
  originAddress      String?
  destinationAddress String?
  googleDistanceKm   Decimal?  @db.Decimal(10, 2)
  meterPhotoUrl      String?
  meterOcrKm         Decimal?  @db.Decimal(10, 2)
  distanceMatch      Boolean?
  transportCost      Decimal?  @db.Decimal(15, 2)
  receiptFileId      String?
  departedAt         DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?
  note               String?
  createdAt          DateTime  @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt          DateTime  @updatedAt

  // 대상 장비 S/N (AS 티켓에서 자동 propagate, 사용자 변경 가능)
  targetEquipmentSN  String?

  asTicket         AsTicket          @relation(fields: [asTicketId], references: [id], onDelete: Cascade)
  dispatchEmployee Employee?         @relation("DispatchEmployee", fields: [dispatchEmployeeId], references: [id])
  receipt          File?             @relation("DispatchReceipt", fields: [receiptFileId], references: [id])
  parts            AsDispatchPart[]

  @@index([asTicketId])
  @@index([targetEquipmentSN])
  @@map("as_dispatches")
}

/// AS 출동 시 사용한 부품 — 출고 자동처리 + 매입원가 자동조회 + 장비 S/N 매핑
model AsDispatchPart {
  id                String     @id @default(cuid())
  asDispatchId      String
  asDispatch        AsDispatch @relation(fields: [asDispatchId], references: [id], onDelete: Cascade)

  itemId            String
  item              Item       @relation(fields: [itemId], references: [id])
  serialNumber      String?    // 부품 자체 S/N (소모품은 없을 수 있음)
  quantity          Int        @default(1)

  // 대상 장비 S/N — 어떤 복합기/장비에 사용했는지 (필수)
  targetEquipmentSN String
  targetContractId  String?    // ItContract id (자동조회로 채움)

  // 매입원가 (자동조회 + 수동수정 가능)
  unitCost          Decimal?   @db.Decimal(15, 2)
  totalCost         Decimal?   @db.Decimal(15, 2)

  // 자동 생성된 출고 트랜잭션과 1:1
  inventoryTxnId    String?              @unique
  inventoryTxn      InventoryTransaction? @relation("DispatchPartTxn", fields: [inventoryTxnId], references: [id])

  note              String?
  createdAt         DateTime   @default(now())

  @@index([asDispatchId])
  @@index([targetEquipmentSN])
  @@index([targetContractId])
  @@map("as_dispatch_parts")
}

// ==================================================
// 매출 / 매입 (4)
// ==================================================

/// 가이드: "회사없음 + 영업담당 추가 + 사용기간(optional)"
model Sales {
  id               String    @id @default(cuid())
  salesNumber      String    @unique
  clientId         String
  projectId        String?
  salesEmployeeId  String?
  warehouseId      String? // TRADE 프로젝트 자동 OUT 대상 창고
  usagePeriodStart DateTime?
  usagePeriodEnd   DateTime?
  totalAmount      Decimal   @db.Decimal(15, 2) // 거래통화(currency) 단위의 합계
  currency         Currency  @default(VND)
  fxRate           Decimal   @default(1) @db.Decimal(15, 6) // 1 단위 currency → VND 환산율
  note             String?
  createdAt        DateTime  @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt        DateTime  @updatedAt

  client          Client              @relation(fields: [clientId], references: [id])
  project         Project?            @relation(fields: [projectId], references: [id])
  items           SalesItem[]
  receivables     PayableReceivable[] @relation("SalesReceivable")
  adjustments     SalesAdjustment[]   @relation("SalesAdjustments")
  linkedExpenses  Expense[]           @relation("ExpenseLinkedSales")

  @@index([clientId])
  @@index([projectId])
  @@map("sales")
}

model SalesItem {
  id                 String         @id @default(cuid())
  salesId            String
  itemId             String
  serialNumber       String?
  stockCheck         StockCheckMode @default(LOOSE)
  quantity           Decimal        @db.Decimal(15, 3)
  unitPrice          Decimal        @db.Decimal(15, 2)
  amount             Decimal        @db.Decimal(15, 2)
  // MAINTENANCE/RENTAL 프로젝트 타입 — 라인별 기간(헤더 기간 자동 복사, 라인별 수정 가능)
  startDate          DateTime?
  endDate            DateTime?
  // 교정(CALIBRATION) 프로젝트 타입인 경우 라인별 성적서 1건
  certNumber         String?        @unique
  certFileId         String?
  issuedAt           DateTime?
  nextDueAt          DateTime?
  alertedAt          DateTime?
  // TmRental → Sales 자동반영의 출처 (있으면 reflect-sales 가 1:1 복제한 것)
  sourceTmRentalItemId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  sales              Sales         @relation(fields: [salesId], references: [id], onDelete: Cascade)
  item               Item          @relation(fields: [itemId], references: [id])
  certFile           File?         @relation(fields: [certFileId], references: [id])
  sourceTmRentalItem TmRentalItem? @relation("TmRentalSalesItemSource", fields: [sourceTmRentalItemId], references: [id])

  @@index([salesId])
  @@index([serialNumber])
  @@index([itemId])
  @@index([nextDueAt])
  @@index([sourceTmRentalItemId])
  @@map("sales_items")
}

model Purchase {
  id                   String    @id @default(cuid())
  purchaseNumber       String    @unique
  supplierId           String
  projectId            String?
  salesEmployeeId      String?
  warehouseId          String? // TRADE 프로젝트 자동 IN 대상 창고
  usagePeriodStart     DateTime?
  usagePeriodEnd       DateTime?
  totalAmount          Decimal   @db.Decimal(15, 2)
  currency             Currency  @default(VND)
  fxRate               Decimal   @default(1) @db.Decimal(15, 6)
  warehouseInboundDone Boolean   @default(false)
  note                 String?
  createdAt            DateTime  @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt            DateTime  @updatedAt

  supplier        Client                 @relation(fields: [supplierId], references: [id])
  project         Project?               @relation(fields: [projectId], references: [id])
  items           PurchaseItem[]
  payables        PayableReceivable[]    @relation("PurchasePayable")
  adjustments     PurchaseAdjustment[]   @relation("PurchaseAdjustments")
  linkedExpenses  Expense[]              @relation("ExpenseLinkedPurchase")

  @@index([supplierId])
  @@index([projectId])
  @@map("purchases")
}

model PurchaseItem {
  id           String         @id @default(cuid())
  purchaseId   String
  itemId       String
  serialNumber String?
  stockCheck   StockCheckMode @default(LOOSE)
  quantity     Decimal        @db.Decimal(15, 3)
  unitPrice    Decimal        @db.Decimal(15, 2)
  amount       Decimal        @db.Decimal(15, 2)
  // MAINTENANCE/RENTAL 프로젝트 타입 — 라인별 기간(헤더 기간 자동 복사, 라인별 수정 가능)
  startDate    DateTime?
  endDate      DateTime?
  // 교정(CALIBRATION) 프로젝트 타입인 경우 라인별 성적서 1건
  certNumber   String?        @unique
  certFileId   String?
  issuedAt     DateTime?
  nextDueAt    DateTime?
  alertedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])
  certFile File?    @relation(fields: [certFileId], references: [id])

  @@index([purchaseId])
  @@index([serialNumber])
  @@index([itemId])
  @@index([nextDueAt])
  @@map("purchase_items")
}

// ==================================================
// 인사 + AI평가 (7)
// ==================================================

model Payroll {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  employeeId  String
  month       DateTime // 월별 급여명세 (첫째 날)
  baseSalary  Decimal     @db.Decimal(15, 2)
  allowances  Decimal     @default(0) @db.Decimal(15, 2)
  deductions  Decimal     @default(0) @db.Decimal(15, 2)
  netPay      Decimal     @db.Decimal(15, 2)
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month])
  @@index([companyCode, month])
  @@map("payroll")
}

model Incentive {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  employeeId  String
  month       DateTime
  source      String // 'TM' or 'IT'
  amount      Decimal     @db.Decimal(15, 2)
  note        String?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyCode, month])
  @@index([employeeId])
  @@map("incentives")
}

model LeaveRecord {
  id          String      @id @default(cuid())
  companyCode CompanyCode
  leaveCode   String      @unique // LV-YYMMDD-###
  employeeId  String
  leaveType   LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Decimal     @db.Decimal(5, 2)
  reason      String?
  reasonVi    String?
  reasonEn    String?
  reasonKo    String?
  originalLang Language?
  approverId  String?
  status      LeaveStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyCode, employeeId])
  @@map("leave_records")
}

/// 사건기반 수시평가 — 대상자 본인 비공개, 상위만 열람, AI 번역, 50자 이상
model Incident {
  id                    String       @id @default(cuid())
  companyCode           CompanyCode
  incidentCode          String       @unique // INC-YYMMDD-###
  authorId              String
  subjectId             String
  type                  IncidentType
  contentVi             String?
  contentEn             String?
  contentKo             String?
  originalLang          Language?
  evidenceFileId        String?
  visibilityManagerOnly Boolean      @default(true)
  createdAt             DateTime     @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt             DateTime     @updatedAt

  author   Employee @relation("IncidentAuthor", fields: [authorId], references: [id])
  subject  Employee @relation("IncidentSubject", fields: [subjectId], references: [id])
  evidence File?    @relation("IncidentEvidence", fields: [evidenceFileId], references: [id])

  @@index([companyCode, subjectId])
  @@index([authorId])
  @@map("incidents")
}

/// 동료 상호평가 (익명, 치우침 자동감지)
model PeerReview {
  id           String      @id @default(cuid())
  companyCode  CompanyCode
  reviewerId   String // 내부 저장 (익명 표시)
  subjectId    String
  period       DateTime // 평가 기간
  score        Decimal     @db.Decimal(5, 2)
  biasDetected Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reviewer Employee @relation("PeerReviewReviewer", fields: [reviewerId], references: [id])
  subject  Employee @relation("PeerReviewSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId, period])
  @@map("peer_reviews")
}

/// AI 종합평가 (9개 지표, 가중치, 항목별+종합 이유, A/B/C/D, 관리자 ±10%)
model Evaluation {
  id                  String          @id @default(cuid())
  companyCode         CompanyCode
  evaluationCode      String          @unique // EVAL-YYMMDD-### (AI종합)
  subjectId           String
  period              DateTime
  // 9개 지표: AS TAT / 출동효율 / 매출기여 / ERP입력속도 / ERP마감준수 / ERP숙련도 / 근태 / 동료평가 / 사건평가
  scoreAsTat          Decimal?        @db.Decimal(5, 2)
  scoreDispatchEff    Decimal?        @db.Decimal(5, 2)
  scoreSalesContrib   Decimal?        @db.Decimal(5, 2)
  scoreErpInputSpeed  Decimal?        @db.Decimal(5, 2)
  scoreErpDeadline    Decimal?        @db.Decimal(5, 2)
  scoreErpMastery     Decimal?        @db.Decimal(5, 2)
  scoreAttendance     Decimal?        @db.Decimal(5, 2)
  scorePeer           Decimal?        @db.Decimal(5, 2)
  scoreIncident       Decimal?        @db.Decimal(5, 2)
  reasonsJson         Json? // 항목별 이유 (AI 생성)
  totalScore          Decimal         @db.Decimal(5, 2)
  totalReason         String?
  grade               EvaluationGrade
  managerAdjustment   Decimal?        @db.Decimal(5, 2) // ±10%
  managerAdjustReason String?
  createdAt           DateTime        @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt           DateTime        @updatedAt

  subject Employee @relation("EvaluationSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId, period])
  @@map("evaluations")
}

/// 정기 인사평가 (5단계, 100점 환산, 질문 사전등록)
model RegularEvaluation {
  id              String      @id @default(cuid())
  companyCode     CompanyCode
  evaluationCode  String      @unique
  reviewerId      String
  subjectId       String
  deadline        DateTime
  submittedAt     DateTime?
  answersJson     Json // 질문 ID -> 5단계 값(10/8/6/4/2)
  normalizedScore Decimal     @db.Decimal(5, 2) // 100점 만점
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reviewer Employee @relation("RegularEvalReviewer", fields: [reviewerId], references: [id])
  subject  Employee @relation("RegularEvalSubject", fields: [subjectId], references: [id])

  @@index([companyCode, subjectId])
  @@map("regular_evaluations")
}

// ==================================================
// 재경 (4)
// ==================================================

/// 가이드: "회사없음"
model Expense {
  id               String      @id @default(cuid())
  expenseCode      String      @unique // EXP-YYMMDD-###
  expenseType      ExpenseType
  linkedSalesId    String?
  linkedPurchaseId String?
  amount           Decimal     @db.Decimal(15, 2)
  currency         Currency    @default(VND)
  fxRate           Decimal     @default(1) @db.Decimal(15, 6)
  note             String?
  incurredAt       DateTime
  createdAt        DateTime    @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt        DateTime    @updatedAt

  allocations    ExpenseAllocation[]
  payables       PayableReceivable[] @relation("ExpensePayable")
  linkedSales    Sales?              @relation("ExpenseLinkedSales", fields: [linkedSalesId], references: [id])
  linkedPurchase Purchase?           @relation("ExpenseLinkedPurchase", fields: [linkedPurchaseId], references: [id])

  @@index([expenseType])
  @@index([linkedSalesId])
  @@index([linkedPurchaseId])
  @@map("expenses")
}

model ExpenseAllocation {
  id           String          @id @default(cuid())
  expenseId    String
  projectId    String?
  departmentId String?
  basis        AllocationBasis
  weight       Decimal         @db.Decimal(10, 4) // 수량 또는 비율
  amount       Decimal         @db.Decimal(15, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  expense    Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  project    Project?    @relation("ExpenseAllocProject", fields: [projectId], references: [id])
  department Department? @relation("ExpenseAllocDept",    fields: [departmentId], references: [id])

  @@index([expenseId])
  @@map("expense_allocations")
}

/// 미지급/미수금 — 매출/매입/비용에서 자동 생성 → 목록 선택 → 입금 확인 + 지연사유만 업데이트
model PayableReceivable {
  id          String                  @id @default(cuid())
  // 회사코드 — 자동생성 시 매출/매입의 sourceCompany 가 주입됨. 기존 행은 NULL(공유 거래처 정책 호환).
  companyCode CompanyCode?
  kind        PayableReceivableKind
  salesId     String?
  purchaseId  String?
  expenseId   String?
  clientId    String?
  amount      Decimal                 @db.Decimal(15, 2)
  paidAmount  Decimal                 @default(0) @db.Decimal(15, 2)
  dueDate     DateTime?
  status      PayableReceivableStatus @default(OPEN)
  createdAt   DateTime                @default(now())
  deletedAt   DateTime?
  lockedAt    DateTime?
  lockReason  String?
  updatedAt   DateTime                @updatedAt

  sales        Sales?        @relation("SalesReceivable", fields: [salesId], references: [id])
  purchase     Purchase?     @relation("PurchasePayable", fields: [purchaseId], references: [id])
  expense      Expense?      @relation("ExpensePayable", fields: [expenseId], references: [id])
  delayReasons DelayReason[]

  @@index([companyCode, kind])
  @@index([kind, status])
  @@index([dueDate])
  @@map("payables_receivables")
}

/// 지연사유 이력 (날짜+내용 복수기록, AI 번역)
model DelayReason {
  id                  String    @id @default(cuid())
  payableReceivableId String
  recordedAt          DateTime  @default(now())
  contentVi           String?
  contentEn           String?
  contentKo           String?
  originalLang        Language?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payableReceivable PayableReceivable @relation(fields: [payableReceivableId], references: [id], onDelete: Cascade)

  @@index([payableReceivableId])
  @@map("delay_reasons")
}

// ==================================================
// 시스템공통 (7)
// ==================================================

model User {
  id               String        @id @default(cuid())
  username         String        @unique
  passwordHash     String
  email            String?       @unique
  employeeId       String?       @unique
  clientId         String?       @unique // 고객 포탈 사용자 — role=CLIENT
  allowedCompanies CompanyCode[]
  role             UserRole
  preferredLang    Language      @default(KO)
  chatDisplayMode  Int           @default(1) // 1/2/3개 언어
  isActive         Boolean       @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  employee        Employee?        @relation(fields: [employeeId], references: [id])
  clientAccount   Client?          @relation("ClientPortalUser", fields: [clientId], references: [id])
  auditLogs       AuditLog[]
  notifications   Notification[]
  chatMessages    ChatMessage[]
  chatRoomMembers ChatRoomMember[]
  filesUploaded   File[]           @relation("FileUploader")
  permissions     UserPermission[]

  @@map("users")
}

// 사용자별 모듈 접근 권한 — 보기(VIEW) / 쓰기(WRITE) / 가림(HIDDEN)
// HIDDEN 이면 사이드바·접근 모두 차단. WRITE 면 작성·수정 모두 가능. VIEW 면 GET 만.
// role=ADMIN 은 자동으로 모든 모듈 WRITE — 이 테이블 무시.
model UserPermission {
  id        String         @id @default(cuid())
  userId    String
  module    PermissionModule
  level     PermissionLevel @default(VIEW)
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@map("user_permissions")
}

enum PermissionLevel {
  HIDDEN
  VIEW
  WRITE
}

enum PermissionModule {
  CLIENTS
  ITEMS
  WAREHOUSES
  EMPLOYEES
  DEPARTMENTS
  PROJECTS
  LICENSES
  SCHEDULES
  SALES
  PURCHASES
  IT_CONTRACTS
  TM_RENTALS
  AS_TICKETS
  AS_DISPATCHES
  CALIBRATIONS
  INVENTORY
  HR_LEAVE
  HR_ONBOARDING
  HR_OFFBOARDING
  HR_INCIDENT
  HR_EVALUATION
  HR_PAYROLL
  HR_INCENTIVE
  FINANCE_PAYABLE
  FINANCE_RECEIVABLE
  FINANCE_EXPENSE
  STATS
  CHAT
  CALENDAR
  AUDIT
  ADMIN
}

model AuditLog {
  id          String       @id @default(cuid())
  companyCode CompanyCode?
  userId      String?
  tableName   String
  recordId    String
  action      String // INSERT / UPDATE / DELETE
  before      Json?
  after       Json?
  occurredAt  DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([companyCode, occurredAt])
  @@map("audit_log")
}

model Notification {
  id          String           @id @default(cuid())
  companyCode CompanyCode?
  userId      String
  type        NotificationType
  titleVi     String?
  titleEn     String?
  titleKo     String?
  bodyVi      String?
  bodyEn      String?
  bodyKo      String?
  linkUrl     String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}

model File {
