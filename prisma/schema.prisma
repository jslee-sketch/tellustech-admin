model OffboardingCard {
  id                  String                      @id @default(cuid())
  companyCode         CompanyCode
  offboardingCode     String                      @unique // OFF-YYMMDD-###
  employeeId          String                      @unique
  returnedItems       Json? // 반납 체크리스트
  paidItems           Json? // 지급
